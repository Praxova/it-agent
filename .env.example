# ── Docker Compose Secrets ────────────────────────────────────
# JWT secret for Admin Portal API tokens (min 32 characters)
JWT_SECRET_KEY=praxova-dev-secret-key-change-in-production-min32chars!

# AD bind password for Admin Portal LDAP authentication
PRAXOVA_AD_BIND_PASSWORD=

# ServiceNow Configuration
# Copy this file to .env and fill in your actual credentials

# ServiceNow instance (without https://)
SERVICENOW_INSTANCE=dev341394.service-now.com

# ServiceNow credentials
SERVICENOW_USERNAME=admin
SERVICENOW_PASSWORD=your_password_here

# Assignment group to monitor (optional, defaults to "Helpdesk")
SERVICENOW_ASSIGNMENT_GROUP=Helpdesk

# Tool Server Configuration
# LDAP/Active Directory settings for password reset tool

# LDAP server hostname or IP
TOOL_SERVER_LDAP_SERVER=172.16.119.20

# LDAP port (389 for standard, 636 for LDAPS)
TOOL_SERVER_LDAP_PORT=389

# Use SSL/TLS for LDAP connection
TOOL_SERVER_LDAP_USE_SSL=false

# Base DN for user searches (e.g., DC=example,DC=com)
TOOL_SERVER_LDAP_BASE_DN=DC=montanifarms,DC=com

# Bind user with password reset permissions (full DN)
TOOL_SERVER_LDAP_BIND_USER=CN=admin,CN=Users,DC=montanifarms,DC=com

# Bind user password
TOOL_SERVER_LDAP_BIND_PASSWORD=your_bind_password_here

# Optional: CA certificate file for LDAPS
# TOOL_SERVER_LDAP_CA_CERT_FILE=/etc/ssl/certs/ca-bundle.crt

# Optional: Validate SSL certificate
# TOOL_SERVER_LDAP_VALIDATE_CERT=true

# Optional: LDAP operation timeout in seconds
# TOOL_SERVER_TIMEOUT=30

# Tool Server API settings
# TOOL_SERVER_HOST=0.0.0.0
# TOOL_SERVER_PORT=8000
# TOOL_SERVER_RELOAD=false

# WinRM Settings (for file permissions)
# Host IP or hostname for WinRM connections
TOOL_SERVER_WINRM_HOST=172.16.119.20

# WinRM credentials (optional - uses LDAP credentials if not specified)
# TOOL_SERVER_WINRM_USERNAME=
# TOOL_SERVER_WINRM_PASSWORD=

# WinRM transport method (ntlm, kerberos, or basic)
# TOOL_SERVER_WINRM_TRANSPORT=ntlm

# File Permission Settings
# Paths that are denied for modification (pattern matching with wildcards)
# TOOL_SERVER_FILE_PERMISSION_DENIED_PATHS=["\\\\*\\C$","\\\\*\\D$","\\\\*\\ADMIN$","\\\\*\\SYSVOL","\\\\*\\NETLOGON"]

# Optional: Allowed paths (empty = all paths except denied)
# TOOL_SERVER_FILE_PERMISSION_ALLOWED_PATHS=[]

# Test user for integration testing
# TEST_USER=testuser1

# Pipeline Configuration
# Settings for the main Lucid IT Agent pipeline

# ServiceNow connection (for pipeline, uses LUCID_ prefix)
LUCID_SERVICENOW_INSTANCE=dev341394.service-now.com
LUCID_SERVICENOW_USERNAME=admin
LUCID_SERVICENOW_PASSWORD=your_password
LUCID_ASSIGNMENT_GROUP=Helpdesk
LUCID_AGENT_USER=Lucid Agent

# Tool Server URL (full URL without /api/v1)
LUCID_TOOL_SERVER_URL=http://127.0.0.1:8100

# LLM configuration (Ollama)
LUCID_OLLAMA_MODEL=llama3.1
LUCID_OLLAMA_BASE_URL=http://localhost:11434

# Confidence thresholds
LUCID_CONFIDENCE_THRESHOLD_AUTO=0.8
LUCID_CONFIDENCE_THRESHOLD_REVIEW=0.6

# Poll interval for daemon mode (seconds)
LUCID_POLL_INTERVAL_SECONDS=30

# Escalation group for tickets that can't be auto-resolved
LUCID_ESCALATION_GROUP=Helpdesk
