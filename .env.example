# ─────────────────────────────────────────────────────────────────
# Praxova IT Agent — Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# SECURITY:
#   - .env is gitignored — never commit credentials
#   - Keep .env permissions restricted: chmod 600 .env
#   - For production, use Docker secrets or a vault instead
# ─────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────

# API key for agent → portal authentication (X-API-Key header).
# Generate in portal UI: Settings → API Keys → Create (Agent role).
LUCID_API_KEY=

# ServiceNow password for the agent's polling account.
# The username is configured in the portal UI (Agent Configuration).
SERVICENOW_PASSWORD=

# ── Optional ─────────────────────────────────────────────────────

# Master passphrase for the portal's encrypted secrets store.
# The portal must unseal on startup before credentials are available.
# Development: uncomment and set a value here.
# Production: use sudo ./scripts/setup-unseal.sh to create
#   /etc/praxova/unseal.env instead. See docs/security/unseal-configuration.md
# PRAXOVA_UNSEAL_PASSPHRASE=dev-passphrase-change-in-production

# AD bind password used by the portal for LDAP authentication.
# Only needed if the portal authenticates admins against Active Directory.
# If using local accounts only, leave empty.
# PRAXOVA_AD_BIND_PASSWORD=
