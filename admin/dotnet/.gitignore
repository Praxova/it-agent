## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio cache/options directory
.vs/

# Visual Studio Code
.vscode/

# Rider
.idea/

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# NuGet Packages
*.nupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets

# Database files
*.db
*.db-shm
*.db-wal

# Log files
logs/
*.log

# Environment files
.env
.env.local

# OS generated files
.DS_Store
Thumbs.db

# Rider
*.sln.iml

# Test coverage
coverage/
*.coverage
*.coveragexml

# Entity Framework Core
**/Migrations/

# Publish profiles
*.pubxml
*.PublishSettings

# ASP.NET Scaffolding
ScaffoldingReadMe.txt
