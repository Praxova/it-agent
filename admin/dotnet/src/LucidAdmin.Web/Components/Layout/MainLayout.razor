@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<MudThemeProvider Theme="_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Fixed="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-3">Lucid Admin Portal</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                @{
                    var authMethod = context.User.FindFirst("AuthenticationMethod")?.Value ?? "Local";
                    var isAd = string.Equals(authMethod, "ActiveDirectory", StringComparison.OrdinalIgnoreCase);
                }
                <MudChip T="string" Size="Size.Small" Color="@(isAd ? Color.Info : Color.Default)" Class="mr-2"
                         Icon="@(isAd ? Icons.Material.Filled.Domain : Icons.Material.Filled.Key)">
                    @(isAd ? "AD" : "Local")
                </MudChip>
                <MudMenu Icon="@Icons.Material.Filled.Person" Color="Color.Inherit">
                    <MudMenuItem>@context.User.Identity?.Name</MudMenuItem>
                    <MudDivider />
                    @if (!isAd)
                    {
                        <MudMenuItem Href="/change-password" Icon="@Icons.Material.Filled.VpnKey">Change Password</MudMenuItem>
                    }
                    <MudMenuItem Href="/logout" Icon="@Icons.Material.Filled.Logout">Logout</MudMenuItem>
                </MudMenu>
            </Authorized>
        </AuthorizeView>
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="@ToggleDarkMode"
                       title="@(_isDarkMode ? "Switch to Light Mode" : "Switch to Dark Mode")" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2" Variant="DrawerVariant.Mini" OpenMiniOnHover="true">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="pt-16 px-4">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = false;

    private MudTheme _theme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#1976D2",
            Secondary = "#00796B",
            AppbarBackground = "#1976D2",
            Background = "#f5f5f5",
            Surface = "#ffffff",
            DrawerBackground = "#ffffff",
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#90CAF9",
            Secondary = "#80CBC4",
            AppbarBackground = "#1e1e1e",
            Background = "#121212",
            Surface = "#1e1e1e",
            DrawerBackground = "#1e1e1e",
        }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var mustChange = authState.User.FindFirst("MustChangePassword")?.Value;

            if (string.Equals(mustChange, "True", StringComparison.OrdinalIgnoreCase))
            {
                var uri = Navigation.ToBaseRelativePath(Navigation.Uri);
                if (!uri.StartsWith("change-password", StringComparison.OrdinalIgnoreCase)
                    && !uri.StartsWith("account/logout", StringComparison.OrdinalIgnoreCase))
                {
                    Navigation.NavigateTo("/change-password", forceLoad: true);
                }
            }
        }
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
    }
}
