@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject LucidAdmin.Core.Interfaces.Services.ISealManager SealManager
@inject IDialogService DialogService

<MudThemeProvider Theme="_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Fixed="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        <MudImage Src="images/it-agent-icon.png" Alt="Praxova IT Agent" Width="32" Height="32" Class="ml-3 mr-2" ObjectFit="ObjectFit.Contain" />
        <MudText Typo="Typo.h6">Praxova IT Agent</MudText>
        <MudSpacer />

        @* Seal status indicator *@
        @if (SealManager.IsUnsealed)
        {
            <MudIcon Icon="@Icons.Material.Filled.LockOpen" Color="Color.Success" Size="Size.Small"
                     Class="mr-2" Title="Secrets store: unsealed" />
        }
        else
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Error" Class="mr-2"
                     Icon="@Icons.Material.Filled.Lock" OnClick="ShowUnsealDialog">
                SEALED
            </MudChip>
        }

        <AuthorizeView>
            <Authorized>
                @{
                    var authMethod = context.User.FindFirst("AuthenticationMethod")?.Value ?? "Local";
                    var isAd = string.Equals(authMethod, "ActiveDirectory", StringComparison.OrdinalIgnoreCase);
                }
                <MudChip T="string" Size="Size.Small" Color="@(isAd ? Color.Info : Color.Default)" Class="mr-2"
                         Icon="@(isAd ? Icons.Material.Filled.Domain : Icons.Material.Filled.Key)">
                    @(isAd ? "AD" : "Local")
                </MudChip>
                <MudMenu Icon="@Icons.Material.Filled.Person" Color="Color.Inherit">
                    <MudMenuItem>@context.User.Identity?.Name</MudMenuItem>
                    <MudDivider />
                    @if (!isAd)
                    {
                        <MudMenuItem Href="/change-password" Icon="@Icons.Material.Filled.VpnKey">Change Password</MudMenuItem>
                    }
                    <MudMenuItem Href="/logout" Icon="@Icons.Material.Filled.Logout">Logout</MudMenuItem>
                </MudMenu>
            </Authorized>
        </AuthorizeView>
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="@ToggleDarkMode"
                       title="@(_isDarkMode ? "Switch to Light Mode" : "Switch to Dark Mode")" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2" Variant="DrawerVariant.Mini" OpenMiniOnHover="true">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="pt-16 px-4">
        @if (!SealManager.IsUnsealed)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="mx-4 mt-4" Dense="true">
                <div class="d-flex align-center">
                    <MudText>Secrets store is sealed. Operations requiring credentials are unavailable.</MudText>
                    <MudButton Color="Color.Inherit" Variant="Variant.Text" Size="Size.Small"
                               Class="ml-4" OnClick="ShowUnsealDialog">Unseal</MudButton>
                </div>
            </MudAlert>
        }
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = false;

    private MudTheme _theme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#0A2463",
            Secondary = "#00B4D8",
            Tertiary = "#48CAE4",
            AppbarBackground = "#0A2463",
            AppbarText = "#E8F1F5",
            DrawerBackground = "#E8F1F5",
            DrawerText = "#212529",
            DrawerIcon = "#0A2463",
            Success = "#06D6A0",
            Warning = "#FFC857",
            Error = "#EF476F",
            Info = "#90E0EF",
            Surface = "#FFFFFF",
            Background = "#F5F5F5",
            TextPrimary = "#212529",
            TextSecondary = "#6C757D",
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#00B4D8",
            Secondary = "#48CAE4",
            Tertiary = "#90E0EF",
            AppbarBackground = "#0A2463",
            AppbarText = "#E8F1F5",
            DrawerBackground = "#1A1A2E",
            DrawerText = "#E8F1F5",
            DrawerIcon = "#00B4D8",
            Success = "#06D6A0",
            Warning = "#FFC857",
            Error = "#EF476F",
            Info = "#90E0EF",
            Surface = "#16213E",
            Background = "#0F1419",
            TextPrimary = "#E8F1F5",
            TextSecondary = "#ADB5BD",
        }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var mustChange = authState.User.FindFirst("MustChangePassword")?.Value;

            if (string.Equals(mustChange, "True", StringComparison.OrdinalIgnoreCase))
            {
                var uri = Navigation.ToBaseRelativePath(Navigation.Uri);
                if (!uri.StartsWith("change-password", StringComparison.OrdinalIgnoreCase)
                    && !uri.StartsWith("account/logout", StringComparison.OrdinalIgnoreCase))
                {
                    Navigation.NavigateTo("/change-password", forceLoad: true);
                }
            }
        }
    }

    private async Task ShowUnsealDialog()
    {
        var requiresInit = SealManager.RequiresInitialization;
        var parameters = new DialogParameters<LucidAdmin.Web.Components.Shared.UnsealDialog>
        {
            { x => x.RequiresInit, requiresInit }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var title = requiresInit ? "Initialize Secrets Store" : "Unseal Secrets Store";
        var dialog = await DialogService.ShowAsync<LucidAdmin.Web.Components.Shared.UnsealDialog>(title, parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            // Force page reload to pick up the unsealed state
            Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
        }
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
    }
}
