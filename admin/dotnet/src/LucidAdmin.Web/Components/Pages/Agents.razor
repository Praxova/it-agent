@page "/agents"
@using LucidAdmin.Web.Models
@using LucidAdmin.Core.Entities
@using LucidAdmin.Core.Enums
@using LucidAdmin.Core.Interfaces.Services
@using System.Net.Http.Json
@using Microsoft.JSInterop
@inject IAgentService AgentService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Agents - Praxova Admin</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" GutterBottom="true">Agents</MudText>
    <MudText Typo="Typo.body1" Class="mb-4">
        Manage AI agent instances that process tickets and orchestrate tool calls.
    </MudText>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (_error != null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
    }
    else
    {
        <!-- Search and Filters -->
        <MudGrid Class="mb-4">
            <MudItem xs="12" sm="6" md="4">
                <MudTextField @bind-Value="_searchText"
                              Label="Search"
                              Placeholder="Search by name or host..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true"
                              DebounceInterval="300"
                              OnDebounceIntervalElapsed="@(() => StateHasChanged())" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect @bind-Value="_statusFilter"
                           Label="Status"
                           T="string"
                           Clearable="true"
                           OnClearButtonClick="@(() => { _statusFilter = null; StateHasChanged(); })">
                    <MudSelectItem Value="@("Idle")">Idle</MudSelectItem>
                    <MudSelectItem Value="@("Processing")">Processing</MudSelectItem>
                    <MudSelectItem Value="@("Error")">Error</MudSelectItem>
                    <MudSelectItem Value="@("Unknown")">Unknown</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect @bind-Value="_enabledFilter"
                           Label="Enabled"
                           T="bool?"
                           Clearable="true"
                           OnClearButtonClick="@(() => { _enabledFilter = null; StateHasChanged(); })">
                    <MudSelectItem Value="@((bool?)true)">Enabled</MudSelectItem>
                    <MudSelectItem Value="@((bool?)false)">Disabled</MudSelectItem>
                </MudSelect>
            </MudItem>
            @if (_isAdmin)
            {
                <MudItem xs="12" sm="6" md="2" Class="d-flex align-center">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="OpenCreateDialog"
                               FullWidth="true">
                        Add Agent
                    </MudButton>
                </MudItem>
            }
        </MudGrid>

        <!-- Agents Table -->
        <MudTable Items="@FilteredAgents"
                  Hover="true"
                  Breakpoint="Breakpoint.Sm"
                  Dense="true"
                  Loading="@_loading"
                  LoadingProgressColor="Color.Info">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Host Name</MudTh>
                <MudTh>LLM Provider</MudTh>
                <MudTh>ServiceNow</MudTh>
                <MudTh>Workflow</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Last Heartbeat</MudTh>
                <MudTh>Tickets</MudTh>
                <MudTh>Enabled</MudTh>
                <MudTh Style="text-align: right;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">
                    <MudText Typo="Typo.body2">
                        <strong>@context.Name</strong>
                    </MudText>
                    @if (!string.IsNullOrEmpty(context.DisplayName))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @context.DisplayName
                        </MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Host Name">
                    <MudText Typo="Typo.body2">@(context.HostName ?? "-")</MudText>
                </MudTd>
                <MudTd DataLabel="LLM Provider">
                    @if (context.LlmServiceAccountId.HasValue)
                    {
                        var account = _serviceAccounts.FirstOrDefault(a => a.Id == context.LlmServiceAccountId);
                        if (account != null)
                        {
                            <MudText Typo="Typo.body2">@(account.DisplayName ?? account.Name)</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@account.Provider</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Color="Color.Warning">Unknown</MudText>
                        }
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Warning">Not configured</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="ServiceNow">
                    @if (context.ServiceNowAccountId.HasValue)
                    {
                        var account = _serviceAccounts.FirstOrDefault(a => a.Id == context.ServiceNowAccountId);
                        if (account != null)
                        {
                            <MudText Typo="Typo.body2">@(account.DisplayName ?? account.Name)</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@account.Provider</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Color="Color.Warning">Unknown</MudText>
                        }
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Warning">Not configured</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Workflow">
                    @if (context.WorkflowDefinitionId.HasValue)
                    {
                        var wf = _workflows.FirstOrDefault(w => w.Id == context.WorkflowDefinitionId);
                        if (wf != null)
                        {
                            <MudText Typo="Typo.body2">@(wf.DisplayName ?? wf.Name)</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">v@(wf.Version)</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Color="Color.Warning">Unknown</MudText>
                        }
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Warning">Not assigned</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="@GetStatusColor(context.Status)">
                        @context.Status
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Last Heartbeat">
                    @if (context.LastHeartbeat.HasValue)
                    {
                        var minutes = (DateTime.UtcNow - context.LastHeartbeat.Value).TotalMinutes;
                        var color = minutes < 5 ? Color.Success : minutes < 15 ? Color.Warning : Color.Error;
                        <MudChip T="string" Size="Size.Small" Color="@color">
                            @GetTimeAgo(context.LastHeartbeat.Value)
                        </MudChip>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Never</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Tickets">
                    <MudText Typo="Typo.body2">@context.TicketsProcessed</MudText>
                </MudTd>
                <MudTd DataLabel="Enabled">
                    @if (context.IsEnabled)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" />
                    }
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    @if (_isAdmin)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       OnClick="@(() => OpenEditDialog(context))"
                                       Title="Edit" />
                    }
                    <MudIconButton Icon="@Icons.Material.Filled.Download"
                                   Color="Color.Info"
                                   Size="Size.Small"
                                   OnClick="@(() => ExportAgent(context.Id, context.Name))"
                                   Title="Export Agent Definition" />
                    @if (_isAdmin)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="@(() => DeleteAgent(context))"
                                       Title="Delete" />
                    }
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText>No agents found.</MudText>
            </NoRecordsContent>
        </MudTable>
    }
</MudContainer>

@code {
    private List<AgentResponse> _agents = new();
    private List<ServiceAccountResponse> _serviceAccounts = new();
    private List<WorkflowListItem> _workflows = new();
    private bool _loading = true;
    private string? _error;
    private string _searchText = "";
    private string? _statusFilter;
    private bool? _enabledFilter;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }
    private bool _isAdmin;

    private IEnumerable<AgentResponse> FilteredAgents =>
        _agents.Where(a =>
            (string.IsNullOrWhiteSpace(_searchText) ||
             a.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
             (a.HostName?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
             (a.DisplayName?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)) &&
            (string.IsNullOrWhiteSpace(_statusFilter) || a.Status == _statusFilter) &&
            (!_enabledFilter.HasValue || a.IsEnabled == _enabledFilter.Value)
        );

    protected override async Task OnInitializedAsync()
    {
        if (AuthState != null)
        {
            var state = await AuthState;
            _isAdmin = state.User.IsInRole("Admin");
        }
        await Task.WhenAll(LoadAgents(), LoadServiceAccounts(), LoadWorkflows());
    }

    private async Task LoadServiceAccounts()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<List<ServiceAccountResponse>>("/api/service-accounts");
            if (response != null)
            {
                _serviceAccounts = response;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load service accounts: {ex.Message}", Severity.Warning);
        }
    }

    private async Task LoadWorkflows()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<List<WorkflowListItem>>("/api/v1/workflows");
            if (response != null)
            {
                _workflows = response;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load workflows: {ex.Message}", Severity.Warning);
        }
    }

    private class WorkflowListItem
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public string? DisplayName { get; set; }
        public string Version { get; set; } = "";
        public bool IsActive { get; set; }
    }

    private async Task LoadAgents()
    {
        _loading = true;
        _error = null;
        try
        {
            var agents = await AgentService.GetAllAsync();
            _agents = agents.Select(MapToResponse).ToList();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load agents: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters();
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseButton = true
        };

        var dialog = await DialogService.ShowAsync<AgentDialog>("Create Agent", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadAgents();
        }
    }

    private async Task OpenEditDialog(AgentResponse agent)
    {
        var parameters = new DialogParameters
        {
            { "ExistingAgent", agent }
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseButton = true
        };

        var dialog = await DialogService.ShowAsync<AgentDialog>("Edit Agent", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadAgents();
        }
    }

    private async Task ExportAgent(Guid id, string name)
    {
        try
        {
            Snackbar.Add($"Exporting agent '{name}'...", Severity.Info);
            var response = await Http.GetAsync($"/api/agents/{id}/export");

            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var fileName = $"{name}_export_{DateTime.Now:yyyyMMdd_HHmmss}.json";
                await JS.InvokeVoidAsync("downloadFile", fileName, json, "application/json");
                Snackbar.Add($"Agent '{name}' exported successfully", Severity.Success);
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Export failed: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteAgent(AgentResponse agent)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Confirm Deletion",
            $"Are you sure you want to delete agent '{agent.Name}'? This action cannot be undone.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed == true)
        {
            try
            {
                await AgentService.DeleteAsync(agent.Id);
                Snackbar.Add($"Agent '{agent.Name}' deleted successfully", Severity.Success);
                await LoadAgents();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting agent: {ex.Message}", Severity.Error);
            }
        }
    }

    private static AgentResponse MapToResponse(Agent agent)
    {
        return new AgentResponse(
            Id: agent.Id,
            Name: agent.Name,
            DisplayName: agent.DisplayName,
            HostName: agent.HostName,
            Description: agent.Description,
            Status: agent.Status.ToString(),
            LlmServiceAccountId: agent.LlmServiceAccountId,
            ServiceNowAccountId: agent.ServiceNowAccountId,
            WorkflowDefinitionId: agent.WorkflowDefinitionId,
            WorkflowName: agent.WorkflowDefinition?.Name,
            AssignmentGroup: agent.AssignmentGroup,
            LastActivity: agent.LastActivity,
            LastHeartbeat: agent.LastHeartbeat,
            TicketsProcessed: agent.TicketsProcessed,
            IsEnabled: agent.IsEnabled,
            CreatedAt: agent.CreatedAt,
            UpdatedAt: agent.UpdatedAt
        );
    }

    private static Color GetStatusColor(string status)
    {
        return status switch
        {
            "Idle" => Color.Info,
            "Processing" => Color.Primary,
            "Error" => Color.Error,
            _ => Color.Default
        };
    }

    private static string GetTimeAgo(DateTime dateTime)
    {
        var timeSpan = DateTime.UtcNow - dateTime;

        if (timeSpan.TotalMinutes < 1)
            return "Just now";
        if (timeSpan.TotalMinutes < 60)
            return $"{(int)timeSpan.TotalMinutes}m ago";
        if (timeSpan.TotalHours < 24)
            return $"{(int)timeSpan.TotalHours}h ago";
        return $"{(int)timeSpan.TotalDays}d ago";
    }
}
