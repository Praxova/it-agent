@page "/change-password"
@attribute [Authorize]
@layout LoginLayout
@inject NavigationManager Navigation

<PageTitle>Change Password - Lucid Admin Portal</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center" Style="height: 100vh;">
    <MudCard Class="pa-4" Elevation="4" Style="width: 100%;">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h4" Align="Align.Center">Change Password</MudText>
                @if (_isForced)
                {
                    <MudAlert Severity="Severity.Warning" Class="mt-3" Dense="true">
                        You must change your default password before continuing.
                    </MudAlert>
                }
                else
                {
                    <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary" Class="mt-1">
                        Update your password
                    </MudText>
                }
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-3">@ErrorMessage</MudAlert>
            }

            <form method="post" action="/account/change-password">
                <MudTextField T="string" Label="Current Password"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              name="currentPassword"
                              id="currentPassword"
                              Required="true"
                              RequiredError="Current password is required"
                              Class="mb-3"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Lock" />

                <MudTextField T="string" Label="New Password"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              name="newPassword"
                              id="newPassword"
                              Required="true"
                              RequiredError="New password is required"
                              HelperText="Min 12 chars, uppercase, lowercase, digit, and special character"
                              Class="mb-3"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.VpnKey" />

                <MudTextField T="string" Label="Confirm New Password"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              name="confirmPassword"
                              id="confirmPassword"
                              Required="true"
                              RequiredError="Password confirmation is required"
                              Class="mb-3"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.VpnKey" />

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           Class="mb-2">
                    Change Password
                </MudButton>

                @if (!_isForced)
                {
                    <MudButton Variant="Variant.Text"
                               Color="Color.Default"
                               FullWidth="true"
                               Href="/">
                        Cancel
                    </MudButton>
                }
            </form>

            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-3" Dense="true">
                <strong>Password requirements:</strong>
                <ul class="mt-1 mb-0" style="padding-left: 1.2em;">
                    <li>At least 12 characters</li>
                    <li>At least one uppercase letter</li>
                    <li>At least one lowercase letter</li>
                    <li>At least one digit</li>
                    <li>At least one special character</li>
                    <li>Cannot contain "admin" or your username</li>
                </ul>
            </MudAlert>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorMessage { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private bool _isForced;

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var mustChange = authState.User.FindFirst("MustChangePassword")?.Value;
            _isForced = string.Equals(mustChange, "True", StringComparison.OrdinalIgnoreCase);
        }
    }
}
