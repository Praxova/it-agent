@page "/examples"
@attribute [Authorize]
@using LucidAdmin.Web.Api.Models.Responses
@using LucidAdmin.Core.Entities
@using LucidAdmin.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject HttpClient Http
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject LucidDbContext Context

<PageTitle>Example Sets - Lucid Admin Portal</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Example Sets</MudText>

<!-- Toolbar -->
<MudPaper Elevation="0" Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" md="4">
            <MudTextField @bind-Value="_searchString"
                          Placeholder="Search example sets..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect @bind-Value="_filterCategoryId"
                       Label="Category"
                       Clearable="true"
                       T="Guid?">
                <MudSelectItem Value="@((Guid?)null)">All Categories</MudSelectItem>
                @if (_categories != null)
                {
                    @foreach (var cat in _categories)
                    {
                        <MudSelectItem Value="@((Guid?)cat.Id)">@cat.DisplayName</MudSelectItem>
                    }
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect @bind-Value="_filterStatus"
                       Label="Status"
                       Clearable="true"
                       T="string?">
                <MudSelectItem Value="@((string?)null)">All</MudSelectItem>
                <MudSelectItem Value="@("active")">Active</MudSelectItem>
                <MudSelectItem Value="@("inactive")">Inactive</MudSelectItem>
            </MudSelect>
        </MudItem>
        @if (_isAdmin)
        {
            <MudItem xs="12" md="2" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="CreateExampleSet"
                           FullWidth="true">
                    Create
                </MudButton>
            </MudItem>
        }
    </MudGrid>
</MudPaper>

<!-- Table -->
@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_exampleSets != null)
{
    <MudTable Items="@FilteredExampleSets"
              Hover="true"
              Dense="false"
              Striped="true"
              Elevation="2">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Category</MudTh>
            <MudTh>Examples</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">
                <MudText Typo="Typo.body2"><strong>@context.Name</strong></MudText>
                @if (!string.IsNullOrWhiteSpace(context.DisplayName))
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.DisplayName</MudText>
                }
                @if (!string.IsNullOrWhiteSpace(context.Description))
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Description</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Category">
                @{ var cat = GetCategory(context.TicketCategoryId); }
                @if (cat != null)
                {
                    <MudChip T="string" Size="Size.Small" Style="@($"background-color: {cat.Color}; color: white;")">
                        @cat.DisplayName
                    </MudChip>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">None</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Examples">
                <MudText Typo="Typo.body2">@context.ExampleCount</MudText>
            </MudTd>
            <MudTd DataLabel="Status">
                @if (context.IsActive)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success">Active</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">Inactive</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Type">
                @if (context.IsBuiltIn)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" title="Built-in example sets cannot be modified">Built-in</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">Custom</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Actions">
                @if (_isAdmin)
                {
                    <MudButtonGroup Size="Size.Small" Variant="Variant.Outlined">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       OnClick="@(() => EditExampleSet(context.Id))"
                                       title="Edit" />
                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                       Color="Color.Info"
                                       Size="Size.Small"
                                       OnClick="@(() => CopyExampleSet(context))"
                                       title="Copy" />
                        @if (!context.IsBuiltIn)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           OnClick="@(() => DeleteExampleSet(context))"
                                           title="Delete" />
                        }
                    </MudButtonGroup>
                }
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No example sets found</MudText>
        </NoRecordsContent>
    </MudTable>
}
else
{
    <MudAlert Severity="Severity.Error">Failed to load example sets</MudAlert>
}

@code {
    private List<ExampleSetResponse>? _exampleSets;
    private List<TicketCategory>? _categories;
    private bool _loading = true;
    private string _searchString = string.Empty;
    private Guid? _filterCategoryId;
    private string? _filterStatus;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }
    private bool _isAdmin;

    private IEnumerable<ExampleSetResponse> FilteredExampleSets
    {
        get
        {
            if (_exampleSets == null) return Enumerable.Empty<ExampleSetResponse>();

            var filtered = _exampleSets.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(_searchString))
            {
                var search = _searchString.ToLowerInvariant();
                filtered = filtered.Where(e =>
                    e.Name.ToLowerInvariant().Contains(search) ||
                    (e.DisplayName?.ToLowerInvariant().Contains(search) ?? false) ||
                    (e.Description?.ToLowerInvariant().Contains(search) ?? false));
            }

            if (_filterCategoryId.HasValue)
            {
                filtered = filtered.Where(e => e.TicketCategoryId == _filterCategoryId.Value);
            }

            if (!string.IsNullOrWhiteSpace(_filterStatus))
            {
                filtered = _filterStatus switch
                {
                    "active" => filtered.Where(e => e.IsActive),
                    "inactive" => filtered.Where(e => !e.IsActive),
                    _ => filtered
                };
            }

            return filtered.OrderBy(e => e.TicketCategoryName).ThenBy(e => e.Name);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState != null)
        {
            var state = await AuthState;
            _isAdmin = state.User.IsInRole("Admin");
        }

        _categories = await Context.TicketCategories
            .Where(c => c.IsActive)
            .OrderBy(c => c.SortOrder)
            .ThenBy(c => c.DisplayName)
            .ToListAsync();

        await LoadExampleSets();
    }

    private async Task LoadExampleSets()
    {
        _loading = true;
        try
        {
            _exampleSets = await Http.GetFromJsonAsync<List<ExampleSetResponse>>("/api/v1/example-sets");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load example sets: {ex.Message}", Severity.Error);
            _exampleSets = null;
        }
        finally
        {
            _loading = false;
        }
    }

    private TicketCategory? GetCategory(Guid? categoryId)
    {
        if (categoryId == null || _categories == null) return null;
        return _categories.FirstOrDefault(c => c.Id == categoryId.Value);
    }

    private void CreateExampleSet()
    {
        Navigation.NavigateTo("/examples/create");
    }

    private void EditExampleSet(Guid id)
    {
        Navigation.NavigateTo($"/examples/edit/{id}");
    }

    private async Task CopyExampleSet(ExampleSetResponse exampleSet)
    {
        var newName = $"{exampleSet.Name}-copy";
        var result = await DialogService.ShowMessageBox(
            "Copy Example Set",
            $"Copy '{exampleSet.Name}'? New name will be '{newName}'.",
            yesText: "Copy",
            cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                var response = await Http.PostAsync($"/api/v1/example-sets/{exampleSet.Id}/copy?newName={Uri.EscapeDataString(newName)}", null);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add($"Example set copied successfully", Severity.Success);
                    await LoadExampleSets();
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    Snackbar.Add($"Failed to copy example set: {error}", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Failed to copy example set: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task DeleteExampleSet(ExampleSetResponse exampleSet)
    {
        var result = await DialogService.ShowMessageBox(
            "Delete Example Set",
            $"Are you sure you want to delete the example set '{exampleSet.Name}'? This will also delete all associated examples.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                var response = await Http.DeleteAsync($"/api/v1/example-sets/{exampleSet.Id}");
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add($"Example set '{exampleSet.Name}' deleted successfully", Severity.Success);
                    await LoadExampleSets();
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    Snackbar.Add($"Failed to delete example set: {error}", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Failed to delete example set: {ex.Message}", Severity.Error);
            }
        }
    }
}
