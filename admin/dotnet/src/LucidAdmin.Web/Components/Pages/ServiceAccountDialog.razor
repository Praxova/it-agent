@using MudBlazor
@using LucidAdmin.Web.Models
@using LucidAdmin.Web.Components.Shared
@using LucidAdmin.Core.Entities
@using LucidAdmin.Core.Enums
@using LucidAdmin.Core.Interfaces.Credentials
@using LucidAdmin.Core.Interfaces.Services
@using LucidAdmin.Core.Models
@inject IServiceAccountService ServiceAccountService
@inject ICredentialService CredentialService
@inject ISnackbar Snackbar
@inject HttpClient Http

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudGrid>
                <!-- Basic Information -->
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.Name"
                                  Label="Name"
                                  Required="true"
                                  RequiredError="Name is required"
                                  Disabled="@(_model.Id.HasValue)" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.DisplayName"
                                  Label="Display Name"
                                  HelperText="Optional friendly name for display" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.Description"
                                  Label="Description"
                                  Lines="2"
                                  HelperText="Optional description" />
                </MudItem>

                <!-- Provider Selection -->
                <MudItem xs="12" md="6">
                    <MudSelect @bind-Value="_model.Provider"
                               Label="Provider"
                               Required="true"
                               RequiredError="Provider is required"
                               Disabled="@(_model.Id.HasValue)"
                               T="string">
                        @foreach (var provider in _providers)
                        {
                            <MudSelectItem Value="@provider.Id">@provider.DisplayName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <!-- Account Type Selection -->
                <MudItem xs="12" md="6">
                    <MudSelect @bind-Value="_model.AccountType"
                               Label="Account Type"
                               Required="true"
                               RequiredError="Account type is required"
                               Disabled="@(string.IsNullOrEmpty(_model.Provider) || _model.Id.HasValue)"
                               T="string">
                        @foreach (var accountType in GetAccountTypes())
                        {
                            <MudSelectItem Value="@accountType.Id">@accountType.DisplayName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <!-- Windows AD Configuration -->
                @if (_model.Provider == "windows-ad")
                {
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_model.Domain"
                                      Label="Domain"
                                      Required="true"
                                      RequiredError="Domain is required"
                                      HelperText="Active Directory domain (e.g., contoso.com)" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.SamAccountName"
                                      Label="SAM Account Name"
                                      Required="true"
                                      RequiredError="SAM Account Name is required"
                                      HelperText="User account name" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.OuPath"
                                      Label="OU Path"
                                      HelperText="Optional OU path (e.g., OU=Users,DC=contoso,DC=com)" />
                    </MudItem>
                }

                <!-- ServiceNow Configuration -->
                @if (_model.Provider == "servicenow")
                {
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_model.InstanceUrl"
                                      Label="Instance URL"
                                      Required="true"
                                      RequiredError="Instance URL is required"
                                      HelperText="ServiceNow instance URL (e.g., https://dev12345.service-now.com)" />
                    </MudItem>

                    @if (_model.AccountType == "basic-auth")
                    {
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_model.Username"
                                          Label="Username"
                                          Required="true"
                                          RequiredError="Username is required" />
                        </MudItem>
                    }
                    else if (_model.AccountType == "oauth")
                    {
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.ClientId"
                                          Label="Client ID"
                                          Required="true"
                                          RequiredError="Client ID is required" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.TokenEndpoint"
                                          Label="Token Endpoint"
                                          Required="true"
                                          RequiredError="Token endpoint is required" />
                        </MudItem>
                    }
                }

                <!-- Ollama Configuration -->
                @if (_model.Provider == "llm-ollama")
                {
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_model.Endpoint"
                                      Label="Endpoint URL"
                                      Required="true"
                                      RequiredError="Endpoint is required"
                                      HelperText="Ollama server URL (e.g., http://localhost:11434)" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.Model"
                                      Label="Model"
                                      Required="true"
                                      RequiredError="Model is required"
                                      HelperText="Model name (e.g., llama3.1, mistral, codellama)" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudNumericField @bind-Value="_model.Temperature"
                                         Label="Temperature"
                                         Min="0.0" Max="2.0" Step="0.1"
                                         HelperText="Response randomness (0.0-2.0, default 0.1)" />
                    </MudItem>
                }

                <!-- OpenAI Configuration -->
                @if (_model.Provider == "llm-openai")
                {
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.Model"
                                      Label="Model"
                                      Required="true"
                                      RequiredError="Model is required"
                                      HelperText="Model name (e.g., gpt-4, gpt-4-turbo, gpt-3.5-turbo)" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudNumericField @bind-Value="_model.Temperature"
                                         Label="Temperature"
                                         Min="0.0" Max="2.0" Step="0.1"
                                         HelperText="Response randomness (0.0-2.0, default 0.1)" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudTextField @bind-Value="_model.Endpoint"
                                      Label="Base URL (Optional)"
                                      HelperText="Custom API endpoint (leave blank for default OpenAI API)" />
                    </MudItem>
                }

                <!-- Anthropic Configuration -->
                @if (_model.Provider == "llm-anthropic")
                {
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.Model"
                                      Label="Model"
                                      Required="true"
                                      RequiredError="Model is required"
                                      HelperText="Model name (e.g., claude-3-opus, claude-3-sonnet, claude-3-haiku)" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudNumericField @bind-Value="_model.Temperature"
                                         Label="Temperature"
                                         Min="0.0" Max="1.0" Step="0.1"
                                         HelperText="Response randomness (0.0-1.0, default 0.1)" />
                    </MudItem>
                }

                <!-- Azure OpenAI Configuration -->
                @if (_model.Provider == "llm-azure-openai")
                {
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_model.Endpoint"
                                      Label="Azure Endpoint"
                                      Required="true"
                                      RequiredError="Endpoint is required"
                                      HelperText="Azure OpenAI endpoint (e.g., https://myresource.openai.azure.com)" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.DeploymentName"
                                      Label="Deployment Name"
                                      Required="true"
                                      RequiredError="Deployment name is required"
                                      HelperText="Your Azure OpenAI deployment name" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.ApiVersion"
                                      Label="API Version"
                                      HelperText="API version (e.g., 2024-02-15-preview)" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudNumericField @bind-Value="_model.Temperature"
                                         Label="Temperature"
                                         Min="0.0" Max="2.0" Step="0.1"
                                         HelperText="Response randomness (0.0-2.0, default 0.1)" />
                    </MudItem>
                }

                <!-- AWS Bedrock Configuration -->
                @if (_model.Provider == "llm-bedrock")
                {
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.Region"
                                      Label="AWS Region"
                                      Required="true"
                                      RequiredError="Region is required"
                                      HelperText="AWS region (e.g., us-east-1, us-west-2)" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.Model"
                                      Label="Model ID"
                                      Required="true"
                                      RequiredError="Model ID is required"
                                      HelperText="Bedrock model ID (e.g., anthropic.claude-3-sonnet-20240229-v1:0)" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudNumericField @bind-Value="_model.Temperature"
                                         Label="Temperature"
                                         Min="0.0" Max="1.0" Step="0.1"
                                         HelperText="Response randomness (0.0-1.0, default 0.1)" />
                    </MudItem>
                }

                <!-- Credential Storage (only show if account type requires credentials) -->
                @if (RequiresCredentials())
                {
                    <MudItem xs="12" md="6">
                        <MudSelect @bind-Value="_model.CredentialStorage"
                                   Label="Credential Storage"
                                   Required="true"
                                   T="CredentialStorageType">
                            <MudSelectItem Value="CredentialStorageType.Database">Database (Encrypted)</MudSelectItem>
                            <MudSelectItem Value="CredentialStorageType.Environment">Environment Variable</MudSelectItem>
                            <MudSelectItem Value="CredentialStorageType.Vault">Vault</MudSelectItem>
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.CredentialReference"
                                      Label="Credential Reference"
                                      Required="@(_model.CredentialStorage != CredentialStorageType.Database)"
                                      RequiredError="Credential reference is required"
                                      HelperText="@GetCredentialReferenceHelperText()" />
                    </MudItem>

                    <!-- Credential Management (Database Storage Only) -->
                    @if (_model.Id.HasValue && _model.CredentialStorage == CredentialStorageType.Database)
                    {
                        <MudItem xs="12">
                            <MudPaper Class="pa-3 mt-2" Elevation="0" Outlined="true">
                                <MudText Typo="Typo.h6" Class="mb-2">Manage Credentials</MudText>

                                @if (_hasCredentials == null)
                                {
                                    <MudProgressLinear Indeterminate="true" Size="Size.Small" />
                                }
                                else if (_hasCredentials == true && !_showCredentialForm)
                                {
                                    <div class="d-flex align-items-center gap-2">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success">Credentials Stored</MudChip>
                                        <MudButton Size="Size.Small"
                                                   Variant="Variant.Text"
                                                   Color="Color.Primary"
                                                   OnClick="@(() => _showCredentialForm = true)">
                                            Update Credentials
                                        </MudButton>
                                        <MudButton Size="Size.Small"
                                                   Variant="Variant.Text"
                                                   Color="Color.Error"
                                                   OnClick="DeleteCredentials">
                                            Delete Credentials
                                        </MudButton>
                                    </div>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2" Class="mb-3">
                                        @(_hasCredentials == false ? "No credentials stored. Add credentials below:" : "Update stored credentials:")
                                    </MudText>

                                    @if (_model.Provider == "servicenow" && _model.AccountType == "basic-auth")
                                    {
                                        <MudTextField @bind-Value="_credUsername"
                                                      Label="Username"
                                                      Class="mb-2" />
                                        <MudTextField @bind-Value="_credPassword"
                                                      Label="Password"
                                                      InputType="InputType.Password"
                                                      Class="mb-2" />
                                    }
                                    else if (_model.Provider == "servicenow" && _model.AccountType == "oauth")
                                    {
                                        <MudTextField @bind-Value="_credClientId"
                                                      Label="Client ID"
                                                      Class="mb-2" />
                                        <MudTextField @bind-Value="_credClientSecret"
                                                      Label="Client Secret"
                                                      InputType="InputType.Password"
                                                      Class="mb-2" />
                                    }
                                    else if ((_model.Provider == "llm-openai" || _model.Provider == "llm-anthropic") && _model.AccountType == "api-key")
                                    {
                                        <MudTextField @bind-Value="_credApiKey"
                                                      Label="API Key"
                                                      InputType="InputType.Password"
                                                      HelperText="@($"Enter your {(_model.Provider == "llm-openai" ? "OpenAI" : "Anthropic")} API key")"
                                                      Class="mb-2" />
                                    }
                                    else if (_model.Provider == "windows-ad" && _model.AccountType == "traditional")
                                    {
                                        <MudTextField @bind-Value="_credUsername"
                                                      Label="Username"
                                                      HelperText="DOMAIN\username or username@domain.com"
                                                      Class="mb-2" />
                                        <MudTextField @bind-Value="_credPassword"
                                                      Label="Password"
                                                      InputType="InputType.Password"
                                                      Class="mb-2" />
                                    }
                                    else if (_model.Provider == "llm-ollama" ||
                                             (_model.Provider == "windows-ad" && (_model.AccountType == "gmsa" || _model.AccountType == "current-user")))
                                    {
                                        <MudAlert Severity="Severity.Info" Dense="true">No credentials required for this account type.</MudAlert>
                                    }
                                    else
                                    {
                                        <MudAlert Severity="Severity.Warning" Dense="true">
                                            Credential form not configured for provider @_model.Provider with account type @_model.AccountType.
                                        </MudAlert>
                                    }

                                    <div class="d-flex gap-2 mt-2">
                                        <MudButton Size="Size.Small"
                                                   Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   OnClick="SaveCredentials"
                                                   Disabled="@_savingCredentials">
                                            @if (_savingCredentials)
                                            {
                                                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                            }
                                            else
                                            {
                                                <span>Save Credentials</span>
                                            }
                                        </MudButton>
                                        @if (_hasCredentials == true)
                                        {
                                            <MudButton Size="Size.Small"
                                                       Variant="Variant.Text"
                                                       OnClick="@(() => { _showCredentialForm = false; ClearCredentialFields(); })">
                                                Cancel
                                            </MudButton>
                                        }
                                    </div>
                                }
                            </MudPaper>
                        </MudItem>
                    }
                }

                <!-- Enabled Toggle -->
                <MudItem xs="12">
                    <MudSwitch @bind-Value="_model.IsEnabled"
                               Label="Enabled"
                               Color="Color.Primary" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Save"
                   Disabled="@(!_isValid || _saving)">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
            else
            {
                @(_model.Id.HasValue ? "Update" : "Create")
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public ServiceAccountResponse? ExistingAccount { get; set; }

    private MudForm _form = null!;
    private bool _isValid;
    private bool _saving;
    private ServiceAccountFormModel _model = new();

    // Credential management fields
    private bool? _hasCredentials;
    private bool _showCredentialForm;
    private bool _savingCredentials;
    private string? _credUsername;
    private string? _credPassword;
    private string? _credApiKey;
    private string? _credClientId;
    private string? _credClientSecret;

    private List<ProviderDto> _providers = new()
    {
        new ProviderDto(
            "windows-ad",
            "Windows Active Directory",
            "Windows AD with gMSA or traditional service accounts",
            new[]
            {
                new AccountTypeDto("gmsa", "Group Managed Service Account (gMSA)", false),
                new AccountTypeDto("traditional", "Traditional Service Account", true),
                new AccountTypeDto("current-user", "Current User Context (Dev Only)", false)
            }
        ),
        new ProviderDto(
            "servicenow",
            "ServiceNow",
            "ServiceNow instance with Basic Auth or OAuth",
            new[]
            {
                new AccountTypeDto("basic-auth", "Basic Authentication", true),
                new AccountTypeDto("oauth", "OAuth 2.0", true)
            }
        ),
        new ProviderDto(
            "llm-ollama",
            "Ollama (Local LLM)",
            "Local LLM server via Ollama",
            new[]
            {
                new AccountTypeDto("local", "Local Instance", false)
            }
        ),
        new ProviderDto(
            "llm-openai",
            "OpenAI",
            "OpenAI API (GPT-4, GPT-3.5, etc.)",
            new[]
            {
                new AccountTypeDto("api-key", "API Key", true)
            }
        ),
        new ProviderDto(
            "llm-anthropic",
            "Anthropic",
            "Anthropic API (Claude models)",
            new[]
            {
                new AccountTypeDto("api-key", "API Key", true)
            }
        ),
        new ProviderDto(
            "llm-azure-openai",
            "Azure OpenAI",
            "Azure-hosted OpenAI service",
            new[]
            {
                new AccountTypeDto("api-key", "API Key", true),
                new AccountTypeDto("managed-identity", "Managed Identity", false)
            }
        ),
        new ProviderDto(
            "llm-bedrock",
            "AWS Bedrock",
            "AWS Bedrock LLM service",
            new[]
            {
                new AccountTypeDto("iam-role", "IAM Role", false),
                new AccountTypeDto("access-key", "Access Key", true)
            }
        )
    };

    protected override async Task OnInitializedAsync()
    {
        if (ExistingAccount != null)
        {
            _model = ServiceAccountFormModel.FromResponse(ExistingAccount);

            // Check if credentials exist for database storage
            if (_model.CredentialStorage == CredentialStorageType.Database)
            {
                await CheckCredentialsExist();
            }
        }
    }

    private async Task CheckCredentialsExist()
    {
        try
        {
            if (_model.Id.HasValue)
            {
                _hasCredentials = await CredentialService.HasCredentialsAsync(_model.Id.Value);
            }
        }
        catch
        {
            _hasCredentials = false;
        }
    }

    private void ClearCredentialFields()
    {
        _credUsername = null;
        _credPassword = null;
        _credApiKey = null;
        _credClientId = null;
        _credClientSecret = null;
    }

    private async Task SaveCredentials()
    {
        if (_model.Id == null) return;

        _savingCredentials = true;
        try
        {
            var credentials = new Dictionary<string, string>();

            if (_model.Provider == "servicenow" && _model.AccountType == "basic-auth")
            {
                if (!string.IsNullOrEmpty(_credUsername)) credentials["username"] = _credUsername;
                if (!string.IsNullOrEmpty(_credPassword)) credentials["password"] = _credPassword;
            }
            else if (_model.Provider == "servicenow" && _model.AccountType == "oauth")
            {
                if (!string.IsNullOrEmpty(_credClientId)) credentials["client_id"] = _credClientId;
                if (!string.IsNullOrEmpty(_credClientSecret)) credentials["client_secret"] = _credClientSecret;
            }
            else if ((_model.Provider == "llm-openai" || _model.Provider == "llm-anthropic") && _model.AccountType == "api-key")
            {
                if (!string.IsNullOrEmpty(_credApiKey)) credentials["api_key"] = _credApiKey;
            }
            else if (_model.Provider == "windows-ad" && _model.AccountType == "traditional")
            {
                if (!string.IsNullOrEmpty(_credUsername)) credentials["username"] = _credUsername;
                if (!string.IsNullOrEmpty(_credPassword)) credentials["password"] = _credPassword;
            }

            var credentialSet = new CredentialSet(credentials);
            var result = await CredentialService.StoreCredentialsAsync(_model.Id.Value, credentialSet);

            if (result.Success)
            {
                Snackbar.Add("Credentials saved successfully", Severity.Success);
                _hasCredentials = true;
                _showCredentialForm = false;
                ClearCredentialFields();
            }
            else
            {
                Snackbar.Add($"Failed to save credentials: {result.ErrorMessage}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving credentials: {ex.Message}", Severity.Error);
        }
        finally
        {
            _savingCredentials = false;
        }
    }

    private async Task DeleteCredentials()
    {
        if (_model.Id == null) return;

        try
        {
            var result = await CredentialService.DeleteCredentialsAsync(_model.Id.Value);

            if (result)
            {
                Snackbar.Add("Credentials deleted successfully", Severity.Success);
                _hasCredentials = false;
                _showCredentialForm = true;
            }
            else
            {
                Snackbar.Add("Failed to delete credentials", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error deleting credentials: {ex.Message}", Severity.Error);
        }
    }

    private IEnumerable<AccountTypeDto> GetAccountTypes()
    {
        if (string.IsNullOrEmpty(_model.Provider))
            return Enumerable.Empty<AccountTypeDto>();

        var provider = _providers.FirstOrDefault(p => p.Id == _model.Provider);
        return provider?.AccountTypes ?? Enumerable.Empty<AccountTypeDto>();
    }

    private bool RequiresCredentials()
    {
        if (string.IsNullOrEmpty(_model.Provider) || string.IsNullOrEmpty(_model.AccountType))
            return false;

        var provider = _providers.FirstOrDefault(p => p.Id == _model.Provider);
        var accountType = provider?.AccountTypes.FirstOrDefault(at => at.Id == _model.AccountType);
        return accountType?.RequiresCredentials ?? false;
    }

    private string GetCredentialReferenceHelperText() => _model.CredentialStorage switch
    {
        CredentialStorageType.Database => "Leave empty for encrypted database storage",
        CredentialStorageType.Environment => "Environment variable name (e.g., LUCID_SVC_PASSWORD)",
        CredentialStorageType.Vault => "Vault path to the secret (e.g., secret/lucid/service-accounts/svc-name)",
        _ => "Reference to where the credential is stored"
    };

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Save()
    {
        await _form.Validate();
        if (!_isValid)
            return;

        _saving = true;
        try
        {
            if (_model.Id.HasValue)
            {
                // Update existing
                var account = await ServiceAccountService.GetByIdAsync(_model.Id.Value);
                if (account == null)
                {
                    Snackbar.Add("Service account not found", Severity.Error);
                    return;
                }

                // Update fields
                account.DisplayName = _model.DisplayName;
                account.Description = _model.Description;
                account.Configuration = _model.ToUpdateRequest().Configuration;
                account.CredentialStorage = _model.CredentialStorage;
                account.CredentialReference = _model.CredentialReference;
                account.IsEnabled = _model.IsEnabled;

                await ServiceAccountService.UpdateAsync(account);
                Snackbar.Add("Service account updated successfully", Severity.Success);
            }
            else
            {
                // Create new
                var account = new ServiceAccount
                {
                    Name = _model.Name,
                    DisplayName = _model.DisplayName,
                    Description = _model.Description,
                    Provider = _model.Provider,
                    AccountType = _model.AccountType,
                    Configuration = _model.ToCreateRequest().Configuration,
                    CredentialStorage = _model.CredentialStorage,
                    CredentialReference = _model.CredentialReference,
                    IsEnabled = _model.IsEnabled
                };

                await ServiceAccountService.CreateAsync(account);
                Snackbar.Add("Service account created successfully", Severity.Success);
            }

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving service account: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
