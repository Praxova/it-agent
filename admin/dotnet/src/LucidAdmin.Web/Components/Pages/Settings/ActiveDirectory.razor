@page "/settings/active-directory"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Options
@attribute [Authorize(Policy = "RequireOperator")]
@inject IOptionsMonitor<LucidAdmin.Web.Models.ActiveDirectoryOptions> AdOptions
@inject LucidAdmin.Web.Services.IAdSettingsService AdService
@inject LucidAdmin.Core.Interfaces.Repositories.IServiceAccountRepository ServiceAccountRepo
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject LucidAdmin.Web.Services.ITrustedCertificateStore TrustedCertStore

<PageTitle>Active Directory Settings - Praxova Admin</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h4" GutterBottom="true">Active Directory Settings</MudText>
    <MudText Typo="Typo.body1" Class="mb-4">
        Configure Active Directory authentication and role mapping.
    </MudText>

    @{
        var config = AdOptions.CurrentValue;
    }

    <!-- Status Banner -->
    @if (config.Enabled)
    {
        <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="mb-4">
            Active Directory authentication is <strong>enabled</strong> for domain <strong>@config.Domain</strong>.
        </MudAlert>
    }
    else
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Class="mb-4">
            Active Directory authentication is <strong>disabled</strong>. Only local accounts can sign in.
        </MudAlert>
    }

    @if (config.Enabled && !config.UseLdaps)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="mb-4"
                  Icon="@Icons.Material.Filled.Warning">
            <MudText>
                <strong>Insecure Connection:</strong> LDAP traffic (including passwords during authentication)
                is sent in plain text. Enable LDAPS to encrypt the connection.
            </MudText>
            @if (_ldapsAvailable)
            {
                <MudButton Variant="Variant.Text" Color="Color.Inherit" Size="Size.Small"
                           OnClick="EnableLdaps" Class="mt-1">
                    Upgrade to LDAPS
                </MudButton>
            }
        </MudAlert>
    }

    <MudGrid>
        <!-- Connection Settings -->
        <MudItem xs="12" md="6">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Connection Settings</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip T="string" Color="@(config.Enabled ? Color.Success : Color.Default)" Size="Size.Small">
                            @(config.Enabled ? "Enabled" : "Disabled")
                        </MudChip>
                        <AuthorizeView Policy="RequireAdmin">
                            @if (!_editing)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               Title="Edit Settings"
                                               OnClick="EnterEditMode" />
                            }
                        </AuthorizeView>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    @if (_editing)
                    {
                        <MudSwitch @bind-Value="_editModel!.Enabled" Label="Enabled" Color="Color.Success" Class="mb-3" />
                        <MudTextField @bind-Value="_editModel!.Domain" Label="Domain" Variant="Variant.Outlined"
                                      HelperText="e.g., montanifarms.com" Class="mb-2" />
                        <MudTextField @bind-Value="_editModel!.LdapServer" Label="LDAP Server" Variant="Variant.Outlined"
                                      HelperText="IP address or hostname" Class="mb-2" />
                        <MudNumericField @bind-Value="_editModel!.LdapPort" Label="LDAP Port" Variant="Variant.Outlined"
                                         Min="1" Max="65535" Class="mb-2" />
                        <MudSwitch T="bool" Value="_editModel!.UseLdaps" Label="Use LDAPS (SSL)" Color="Color.Primary"
                                   ValueChanged="OnLdapsToggled" Class="mb-2" />
                        <MudTextField @bind-Value="_editModel!.SearchBase" Label="Search Base" Variant="Variant.Outlined"
                                      HelperText="e.g., DC=montanifarms,DC=com" Class="mb-2" />

                        <MudText Typo="Typo.subtitle2" Class="mt-3 mb-1">LDAP Bind Credentials</MudText>
                        @if (_adServiceAccounts != null && _adServiceAccounts.Count > 0)
                        {
                            <MudSelect T="Guid?" @bind-Value="_editModel!.LdapServiceAccountId"
                                       Label="Service Account for LDAP Bind"
                                       Variant="Variant.Outlined" Class="mb-2"
                                       Clearable="true"
                                       HelperText="Used for Test Connection and group search. User auth uses the user's own credentials.">
                                <MudSelectItem T="Guid?" Value="@((Guid?)null)">(None — anonymous bind)</MudSelectItem>
                                @foreach (var sa in _adServiceAccounts)
                                {
                                    <MudSelectItem T="Guid?" Value="@sa.Id">@(sa.DisplayName ?? sa.Name)</MudSelectItem>
                                }
                            </MudSelect>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-2">
                                No <strong>windows-ad</strong> service accounts found.
                                <MudLink Href="/service-accounts/create" Typo="Typo.body2">Create one</MudLink> to enable authenticated LDAP bind.
                            </MudAlert>
                        }

                        @if (!string.IsNullOrEmpty(_editModel!.BindUserDn))
                        {
                            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mb-2">
                                Legacy bind fields are deprecated. Select a Service Account above and clear these fields.
                            </MudAlert>
                            <MudTextField @bind-Value="_editModel!.BindUserDn" Label="Bind User DN (deprecated)" Variant="Variant.Outlined"
                                          HelperText="Clear this field after selecting a Service Account" Class="mb-2" />
                            <MudTextField @bind-Value="_editModel!.BindPasswordEnvVar" Label="Bind Password Env Var (deprecated)" Variant="Variant.Outlined"
                                          HelperText="Clear this field after selecting a Service Account" Class="mb-2" />
                        }
                        <MudSelect @bind-Value="_editModel!.DefaultRole" Label="Default Role" Variant="Variant.Outlined" Class="mb-2">
                            <MudSelectItem Value="@("Viewer")">Viewer</MudSelectItem>
                            <MudSelectItem Value="@("Operator")">Operator</MudSelectItem>
                            <MudSelectItem Value="@("Admin")">Admin</MudSelectItem>
                        </MudSelect>
                        <MudSwitch @bind-Value="_editModel!.RequireRoleGroup" Label="Require Role Group"
                                   Color="Color.Warning" Class="mb-2"
                                   HelperText="When enabled, users must be in a mapped group to log in" />
                    }
                    else
                    {
                        <MudSimpleTable Dense="true" Hover="true">
                            <tbody>
                                <tr><td><strong>Domain</strong></td><td>@(string.IsNullOrEmpty(config.Domain) ? "\u2014" : config.Domain)</td></tr>
                                <tr><td><strong>LDAP Server</strong></td><td>@(string.IsNullOrEmpty(config.LdapServer) ? "\u2014" : config.LdapServer)</td></tr>
                                <tr><td><strong>LDAP Port</strong></td><td>@config.LdapPort</td></tr>
                                <tr><td><strong>Use LDAPS</strong></td><td>@(config.UseLdaps ? "Yes (SSL)" : "No (Plain)")</td></tr>
                                <tr><td><strong>Search Base</strong></td><td><code>@(string.IsNullOrEmpty(config.SearchBase) ? "\u2014" : config.SearchBase)</code></td></tr>
                                <tr><td><strong>LDAP Bind</strong></td><td>@GetBindDisplayText(config)</td></tr>
                                <tr><td><strong>Default Role</strong></td><td>@config.DefaultRole</td></tr>
                                <tr><td><strong>Require Role Group</strong></td><td>@(config.RequireRoleGroup ? "Yes" : "No")</td></tr>
                            </tbody>
                        </MudSimpleTable>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Role Mapping -->
        <MudItem xs="12" md="6">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Role Mapping</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (_editing)
                    {
                        <div class="d-flex align-center gap-2 mb-3">
                            <MudTextField @bind-Value="_editModel!.RoleMapping.AdminGroup"
                                          Label="Admin Group" Variant="Variant.Outlined"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.AdminPanelSettings"
                                          Style="flex: 1;" />
                            <MudIconButton Icon="@Icons.Material.Filled.Search"
                                           Color="Color.Primary"
                                           Variant="Variant.Outlined"
                                           Title="Browse AD Groups"
                                           OnClick="@(() => BrowseAdGroup(nameof(_editModel.RoleMapping.AdminGroup)))" />
                        </div>
                        <div class="d-flex align-center gap-2 mb-3">
                            <MudTextField @bind-Value="_editModel!.RoleMapping.OperatorGroup"
                                          Label="Operator Group" Variant="Variant.Outlined"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Engineering"
                                          Style="flex: 1;" />
                            <MudIconButton Icon="@Icons.Material.Filled.Search"
                                           Color="Color.Primary"
                                           Variant="Variant.Outlined"
                                           Title="Browse AD Groups"
                                           OnClick="@(() => BrowseAdGroup(nameof(_editModel.RoleMapping.OperatorGroup)))" />
                        </div>
                        <div class="d-flex align-center gap-2 mb-3">
                            <MudTextField @bind-Value="_editModel!.RoleMapping.ViewerGroup"
                                          Label="Viewer Group" Variant="Variant.Outlined"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Visibility"
                                          Style="flex: 1;" />
                            <MudIconButton Icon="@Icons.Material.Filled.Search"
                                           Color="Color.Primary"
                                           Variant="Variant.Outlined"
                                           Title="Browse AD Groups"
                                           OnClick="@(() => BrowseAdGroup(nameof(_editModel.RoleMapping.ViewerGroup)))" />
                        </div>
                    }
                    else
                    {
                        <MudSimpleTable Dense="true" Hover="true">
                            <thead>
                                <tr>
                                    <th>AD Group</th>
                                    <th>Portal Role</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><code>@config.RoleMapping.AdminGroup</code></td>
                                    <td><MudChip T="string" Color="Color.Error" Size="Size.Small">Admin</MudChip></td>
                                </tr>
                                <tr>
                                    <td><code>@config.RoleMapping.OperatorGroup</code></td>
                                    <td><MudChip T="string" Color="Color.Warning" Size="Size.Small">Operator</MudChip></td>
                                </tr>
                                <tr>
                                    <td><code>@config.RoleMapping.ViewerGroup</code></td>
                                    <td><MudChip T="string" Color="Color.Info" Size="Size.Small">Viewer</MudChip></td>
                                </tr>
                            </tbody>
                        </MudSimpleTable>
                        <MudText Typo="Typo.caption" Class="mt-2" Color="Color.Secondary">
                            Users not in any group receive the <strong>@config.DefaultRole</strong> role.
                            @if (config.RequireRoleGroup)
                            {
                                <span> Access is <strong>denied</strong> for users without a matching group.</span>
                            }
                        </MudText>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Save / Cancel buttons (edit mode) -->
        @if (_editing)
        {
            <MudItem xs="12">
                <div class="d-flex gap-2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Save"
                               OnClick="SaveSettings" Disabled="_saving">
                        @if (_saving)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Saving...</span>
                        }
                        else
                        {
                            <span>Save Settings</span>
                        }
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default"
                               OnClick="CancelEdit" Disabled="_saving">
                        Cancel
                    </MudButton>
                </div>
            </MudItem>
        }

        <!-- Connection Test -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Connection Test</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (!config.Enabled && !(_editing && _editModel!.Enabled))
                    {
                        <MudText Color="Color.Secondary">Enable Active Directory to test connectivity.</MudText>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.NetworkCheck"
                                   OnClick="TestConnection"
                                   Disabled="_testing">
                            @if (_testing)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Testing...</span>
                            }
                            else
                            {
                                <span>Test Connection</span>
                            }
                        </MudButton>

                        @if (_testResult != null)
                        {
                            <MudAlert Severity="@(_testResult.Reachable ? Severity.Success : Severity.Error)"
                                      Class="mt-3"
                                      Variant="Variant.Outlined">
                                @if (_testResult.Reachable)
                                {
                                    <span>Connected to <strong>@_testResult.Server</strong> (@_testResult.Domain) in <strong>@_testResult.LatencyMs ms</strong></span>
                                }
                                else if (!string.IsNullOrEmpty(_testResult.Error))
                                {
                                    <span>@_testResult.Error</span>
                                }
                                else
                                {
                                    <span>Cannot reach <strong>@_testResult.Server</strong> — verify the server address and ensure the LDAP port is open.</span>
                                }
                            </MudAlert>
                        }
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* LDAPS Certificate Diagnostics *@
        @if (_testResult?.Ldaps != null)
        {
            <MudItem xs="12">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">LDAPS Certificate</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_testResult.Ldaps.ServerCertificate != null)
                        {
                            var cert = _testResult.Ldaps.ServerCertificate;
                            <MudSimpleTable Dense="true">
                                <tbody>
                                    <tr><td><strong>Subject</strong></td><td>@cert.Subject</td></tr>
                                    <tr><td><strong>Issuer</strong></td><td>@cert.Issuer</td></tr>
                                    <tr>
                                        <td><strong>Valid Until</strong></td>
                                        <td>
                                            @cert.NotAfter.ToString("yyyy-MM-dd")
                                            @if (cert.IsExpired)
                                            {
                                                <MudChip T="string" Color="Color.Error" Size="Size.Small">Expired</MudChip>
                                            }
                                            else if (cert.DaysUntilExpiry < 30)
                                            {
                                                <MudChip T="string" Color="Color.Warning" Size="Size.Small">
                                                    @cert.DaysUntilExpiry days remaining
                                                </MudChip>
                                            }
                                            else
                                            {
                                                <MudChip T="string" Color="Color.Success" Size="Size.Small">
                                                    @cert.DaysUntilExpiry days remaining
                                                </MudChip>
                                            }
                                        </td>
                                    </tr>
                                    <tr><td><strong>Thumbprint</strong></td><td><code>@cert.Thumbprint[..Math.Min(16, cert.Thumbprint.Length)]...</code></td></tr>
                                    <tr>
                                        <td><strong>Trusted</strong></td>
                                        <td>
                                            @if (_testResult.Ldaps.CertTrusted)
                                            {
                                                <MudChip T="string" Color="Color.Success" Size="Size.Small"
                                                         Icon="@Icons.Material.Filled.Verified">Trusted</MudChip>
                                            }
                                            else
                                            {
                                                <MudChip T="string" Color="Color.Error" Size="Size.Small"
                                                         Icon="@Icons.Material.Filled.GppBad">Not Trusted</MudChip>
                                            }
                                        </td>
                                    </tr>
                                </tbody>
                            </MudSimpleTable>

                            @if (!_testResult.Ldaps.CertTrusted)
                            {
                                <MudAlert Severity="Severity.Info" Class="mt-3" Variant="Variant.Outlined">
                                    This certificate is not in Praxova's trust store. LDAPS connections will fail
                                    until the certificate (or its issuing CA) is trusted.
                                </MudAlert>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.VerifiedUser"
                                           OnClick="TrustDcCertificate" Class="mt-2"
                                           Disabled="_importing">
                                    @if (_importing)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                        <span>Importing...</span>
                                    }
                                    else
                                    {
                                        <span>Trust This Certificate</span>
                                    }
                                </MudButton>
                            }
                        }
                        else if (_testResult.Ldaps.TlsError != null)
                        {
                            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
                                @_testResult.Ldaps.TlsError
                            </MudAlert>
                        }
                        else if (!_testResult.Ldaps.PortOpen)
                        {
                            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                                Port 636 is not reachable on @_testResult.Server. LDAPS may not be enabled
                                on the domain controller, or a firewall is blocking the port.
                            </MudAlert>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }

        <!-- Session Behavior -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Role Refresh Behavior</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2" Class="mb-1">
                        When an AD user's group membership changes, their portal role updates on <strong>next login</strong>.
                        Active sessions (up to 8 hours) retain the role assigned at login time.
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        To force an immediate role update, the user must log out and log back in.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        @* Trusted Certificates *@
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Trusted Certificates</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                       Size="Size.Small" OnClick="LoadTrustedCerts" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    @if (_trustedCerts == null || _trustedCerts.Count == 0)
                    {
                        <MudText Color="Color.Secondary">
                            No certificates have been manually imported.
                            Built-in OS certificates and the Praxova internal CA are always trusted.
                        </MudText>
                    }
                    else
                    {
                        <MudTable Items="_trustedCerts" Dense="true" Hover="true">
                            <HeaderContent>
                                <MudTh>Name</MudTh>
                                <MudTh>Subject</MudTh>
                                <MudTh>Expires</MudTh>
                                <MudTh>Imported</MudTh>
                                <MudTh></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.FriendlyName</MudTd>
                                <MudTd><code>@context.Subject</code></MudTd>
                                <MudTd>
                                    @context.NotAfter.ToString("yyyy-MM-dd")
                                    @if (context.IsExpired)
                                    {
                                        <MudChip T="string" Color="Color.Error" Size="Size.Small">Expired</MudChip>
                                    }
                                </MudTd>
                                <MudTd>@context.ImportedAt.ToString("yyyy-MM-dd")</MudTd>
                                <MudTd>
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Color="Color.Error" Size="Size.Small"
                                                   OnClick="@(() => RemoveTrustedCert(context.Thumbprint))" />
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private bool _editing = false;
    private bool _saving = false;
    private bool _testing = false;
    private bool _importing = false;
    private bool _ldapsAvailable = false;
    private AdStatusResult? _testResult;
    private EditModel? _editModel;
    private List<LucidAdmin.Core.Entities.ServiceAccount>? _adServiceAccounts;
    private List<LucidAdmin.Web.Services.TrustedCertEntry>? _trustedCerts;

    protected override async Task OnInitializedAsync()
    {
        var accounts = await ServiceAccountRepo.GetByProviderAsync("windows-ad");
        _adServiceAccounts = accounts.Where(a => a.IsEnabled).ToList();
        await LoadTrustedCerts();
    }

    private void EnterEditMode()
    {
        var config = AdOptions.CurrentValue;
        _editModel = new EditModel
        {
            Enabled = config.Enabled,
            Domain = config.Domain,
            LdapServer = config.LdapServer,
            LdapPort = config.LdapPort,
            UseLdaps = config.UseLdaps,
            SearchBase = config.SearchBase,
            LdapServiceAccountId = config.LdapServiceAccountId,
            BindUserDn = config.BindUserDn,
            BindPasswordEnvVar = config.BindPasswordEnvVar,
            DefaultRole = config.DefaultRole,
            RequireRoleGroup = config.RequireRoleGroup,
            RoleMapping = new EditRoleMapping
            {
                AdminGroup = config.RoleMapping.AdminGroup,
                OperatorGroup = config.RoleMapping.OperatorGroup,
                ViewerGroup = config.RoleMapping.ViewerGroup
            }
        };
        _editing = true;
        _testResult = null;
    }

    private void CancelEdit()
    {
        _editing = false;
        _editModel = null;
    }

    private void OnLdapsToggled(bool useLdaps)
    {
        _editModel!.UseLdaps = useLdaps;
        if (useLdaps && _editModel.LdapPort == 389)
            _editModel.LdapPort = 636;
        else if (!useLdaps && _editModel.LdapPort == 636)
            _editModel.LdapPort = 389;
    }

    private async Task SaveSettings()
    {
        _saving = true;
        StateHasChanged();

        try
        {
            var settings = new LucidAdmin.Web.Models.ActiveDirectoryOptions
            {
                Enabled = _editModel!.Enabled,
                Domain = _editModel.Domain,
                LdapServer = _editModel.LdapServer,
                LdapPort = _editModel.LdapPort,
                UseLdaps = _editModel.UseLdaps,
                SearchBase = _editModel.SearchBase,
                LdapServiceAccountId = _editModel.LdapServiceAccountId,
                BindUserDn = _editModel.BindUserDn,
                BindPasswordEnvVar = _editModel.BindPasswordEnvVar,
                DefaultRole = _editModel.DefaultRole,
                RequireRoleGroup = _editModel.RequireRoleGroup,
                RoleMapping = new LucidAdmin.Web.Models.RoleMappingOptions
                {
                    AdminGroup = _editModel.RoleMapping.AdminGroup,
                    OperatorGroup = _editModel.RoleMapping.OperatorGroup,
                    ViewerGroup = _editModel.RoleMapping.ViewerGroup
                }
            };

            var (success, error) = await AdService.SaveSettingsAsync(settings);

            if (success)
            {
                Snackbar.Add("Active Directory settings saved. Changes take effect immediately.", Severity.Success);
                _editing = false;
                _editModel = null;
            }
            else
            {
                Snackbar.Add(error ?? "Save failed.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private async Task BrowseAdGroup(string fieldName)
    {
        var currentValue = fieldName switch
        {
            nameof(EditRoleMapping.AdminGroup) => _editModel?.RoleMapping.AdminGroup,
            nameof(EditRoleMapping.OperatorGroup) => _editModel?.RoleMapping.OperatorGroup,
            nameof(EditRoleMapping.ViewerGroup) => _editModel?.RoleMapping.ViewerGroup,
            _ => ""
        };

        var parameters = new DialogParameters<LucidAdmin.Web.Components.Shared.AdGroupPickerDialog>
        {
            { x => x.CurrentValue, currentValue }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<LucidAdmin.Web.Components.Shared.AdGroupPickerDialog>(
            "Select AD Group", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled && result.Data is string selectedGroup)
        {
            switch (fieldName)
            {
                case nameof(EditRoleMapping.AdminGroup):
                    _editModel!.RoleMapping.AdminGroup = selectedGroup;
                    break;
                case nameof(EditRoleMapping.OperatorGroup):
                    _editModel!.RoleMapping.OperatorGroup = selectedGroup;
                    break;
                case nameof(EditRoleMapping.ViewerGroup):
                    _editModel!.RoleMapping.ViewerGroup = selectedGroup;
                    break;
            }
            StateHasChanged();
        }
    }

    private async Task TestConnection()
    {
        _testing = true;
        StateHasChanged();

        try
        {
            var result = await AdService.TestConnectionAsync();
            _testResult = new AdStatusResult
            {
                Enabled = result.Enabled,
                Server = result.Server,
                Domain = result.Domain,
                Reachable = result.Reachable,
                LatencyMs = result.LatencyMs,
                Error = result.Error,
                Ldaps = result.Ldaps
            };

            // Track if LDAPS is available (port 636 open)
            _ldapsAvailable = result.Ldaps?.PortOpen == true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Connection test failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _testing = false;
            StateHasChanged();
        }
    }

    private async Task LoadTrustedCerts()
    {
        _trustedCerts = (await TrustedCertStore.ListTrustedCertsAsync()).ToList();
        StateHasChanged();
    }

    private async Task TrustDcCertificate()
    {
        if (_testResult?.Ldaps?.ServerCertificate == null) return;
        _importing = true;
        StateHasChanged();

        try
        {
            var cert = _testResult.Ldaps.ServerCertificate;
            var result = await TrustedCertStore.ImportCertificateAsync(
                cert.Pem,
                $"DC LDAPS - {_testResult.Server}");

            if (result.Success)
            {
                Snackbar.Add("Certificate imported and trusted. LDAPS connections should now work.", Severity.Success);
                await LoadTrustedCerts();
                await TestConnection();
            }
            else
            {
                Snackbar.Add($"Import failed: {result.Error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Import failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _importing = false;
            StateHasChanged();
        }
    }

    private async Task RemoveTrustedCert(string thumbprint)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Remove Trusted Certificate",
            "This will remove the certificate from the trust store. LDAPS connections using this certificate may stop working.",
            "Remove", cancelText: "Cancel");
        if (confirmed != true) return;

        await TrustedCertStore.RemoveCertificateAsync(thumbprint);
        Snackbar.Add("Certificate removed from trust store.", Severity.Info);
        await LoadTrustedCerts();
    }

    private void EnableLdaps()
    {
        EnterEditMode();
        _editModel!.UseLdaps = true;
        _editModel.LdapPort = 636;
    }

    private record AdStatusResult
    {
        public bool Enabled { get; init; }
        public string Server { get; init; } = "";
        public string Domain { get; init; } = "";
        public bool Reachable { get; init; }
        public long LatencyMs { get; init; }
        public string? Error { get; init; }
        public LucidAdmin.Web.Services.LdapsStatus? Ldaps { get; init; }
    }

    private string GetBindDisplayText(LucidAdmin.Web.Models.ActiveDirectoryOptions config)
    {
        if (config.LdapServiceAccountId.HasValue)
        {
            var sa = _adServiceAccounts?.FirstOrDefault(a => a.Id == config.LdapServiceAccountId.Value);
            return sa != null ? $"Service Account: {sa.DisplayName ?? sa.Name}" : $"Service Account ID: {config.LdapServiceAccountId}";
        }
        if (!string.IsNullOrEmpty(config.BindUserDn))
            return $"{config.BindUserDn} (legacy)";
        return "Anonymous";
    }

    private class EditModel
    {
        public bool Enabled { get; set; }
        public string Domain { get; set; } = "";
        public string LdapServer { get; set; } = "";
        public int LdapPort { get; set; } = 389;
        public bool UseLdaps { get; set; }
        public string SearchBase { get; set; } = "";
        public Guid? LdapServiceAccountId { get; set; }
        public string BindUserDn { get; set; } = "";
        public string BindPasswordEnvVar { get; set; } = "";
        public string DefaultRole { get; set; } = "Viewer";
        public bool RequireRoleGroup { get; set; }
        public EditRoleMapping RoleMapping { get; set; } = new();
    }

    private class EditRoleMapping
    {
