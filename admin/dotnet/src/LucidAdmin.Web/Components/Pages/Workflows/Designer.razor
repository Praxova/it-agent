@page "/workflows/designer/{Id:guid}"
@page "/workflows/designer/create"
@attribute [Authorize]
@using LucidAdmin.Web.Api.Models.Requests
@using LucidAdmin.Web.Api.Models.Responses
@using LucidAdmin.Core.Enums
@using LucidAdmin.Web.Components.WorkflowDesigner.Models
@using LucidAdmin.Web.Components.WorkflowDesigner.Widgets
@using System.Text.Json
@using System.Text.Json.Nodes
@using Blazor.Diagrams
@using Blazor.Diagrams.Core
@using Blazor.Diagrams.Core.Anchors
@using Blazor.Diagrams.Core.Geometry
@using Blazor.Diagrams.Core.Models
@using Blazor.Diagrams.Core.Models.Base
@using Blazor.Diagrams.Core.PathGenerators
@using Blazor.Diagrams.Core.Routers
@using Blazor.Diagrams.Components
@using Blazor.Diagrams.Options
@implements IDisposable
@inject HttpClient Http
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>@(_isNew ? "Create Workflow" : "Edit Workflow") - Lucid Admin</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4 pa-0" Style="height: calc(100vh - 100px);">
    <MudGrid Style="height: 100%;">
        @* Left Sidebar *@
        <MudItem xs="12" md="3" Style="height: 100%; overflow-y: auto;">
            <MudPaper Class="pa-3" Style="height: 100%;">
                <MudExpansionPanels Multi Expansion="true">
                    <MudExpansionPanel Text="Workflow Details" IsInitiallyExpanded="true">
                        <MudTextField @bind-Value="_name" Label="Name" Required="true"
                                      Disabled="@(!_isNew)" Class="mb-2"
                                      HelperText="Unique identifier" />
                        <MudTextField @bind-Value="_displayName" Label="Display Name" Class="mb-2" />
                        <MudTextField @bind-Value="_description" Label="Description" Lines="2" Class="mb-2" />
                        <MudSelect @bind-Value="_exampleSetId" Label="Example Set" Class="mb-2"
                                   Clearable="true" T="Guid?">
                            @foreach (var es in _exampleSets)
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)es.Id)">@(es.DisplayName ?? es.Name)</MudSelectItem>
                            }
                        </MudSelect>
                        <MudSwitch T="bool" @bind-Value="_isActive" Label="Active" Color="Color.Primary" />
                    </MudExpansionPanel>

                    @* Step Palette *@
                    <MudExpansionPanel Text="Step Palette" IsInitiallyExpanded="true">
                        <MudText Typo="Typo.caption" Class="mb-2">Click to add steps to the canvas</MudText>
                        @foreach (var stepType in _stepTypes)
                        {
                            <MudPaper Class="pa-2 mb-2 step-palette-item" Elevation="1"
                                      Style="@($"border-left: 4px solid {stepType.Color}; cursor: pointer;")"
                                      @onclick="@(() => AddStepFromPalette(stepType))">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudText>@stepType.Icon</MudText>
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.body2">@stepType.Name</MudText>
                                        <MudText Typo="Typo.caption" Style="font-size: 0.7em;">@stepType.Description</MudText>
                                    </MudStack>
                                </MudStack>
                            </MudPaper>
                        }

                        @* Divider and sub-workflow shortcuts *@
                        @if (_availableWorkflows.Any(w => w.IsActive && w.Id != Id))
                        {
                            <MudDivider Class="my-2" />
                            <MudText Typo="Typo.overline" Class="mb-1">Sub-Workflows</MudText>
                            @foreach (var wf in _availableWorkflows.Where(w => w.IsActive && w.Id != Id))
                            {
                                <MudPaper Class="pa-2 mb-2 step-palette-item" Elevation="1"
                                          Style="border-left: 4px solid #009688; cursor: pointer;"
                                          @onclick="@(() => AddSubWorkflowFromPalette(wf))">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudText>📋</MudText>
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.body2">@(wf.DisplayName ?? wf.Name)</MudText>
                                            <MudText Typo="Typo.caption" Style="font-size: 0.7em;">Sub-workflow</MudText>
                                        </MudStack>
                                    </MudStack>
                                </MudPaper>
                            }
                        }
                    </MudExpansionPanel>

                    @* Selected Node Properties *@
                    @if (_selectedStep != null)
                    {
                        <MudExpansionPanel Text="Step Properties" IsInitiallyExpanded="true">
                            <MudTextField Value="@_stepEdit_Name"
                                          ValueChanged="@((string val) => UpdateStepName(val))"
                                          Label="Step Name" Class="mb-2" />
                            <MudTextField Value="@_stepEdit_DisplayName"
                                          ValueChanged="@((string val) => UpdateStepDisplayName(val))"
                                          Label="Display Name" Class="mb-2" />
                            <MudText Typo="Typo.overline">Type: @_selectedStep.StepType</MudText>

                            @* Type-specific configuration *@
                            @switch (_selectedStep.StepType)
                            {
                                case StepType.Trigger:
                                    <MudSelect @bind-Value="_stepConfig_TriggerSource" Label="Trigger Source" Class="mb-2" T="string">
                                        <MudSelectItem Value="@("servicenow")">ServiceNow</MudSelectItem>
                                        <MudSelectItem Value="@("manual")">Manual</MudSelectItem>
                                    </MudSelect>
                                    break;
                                case StepType.Execute:
                                    <MudTextField @bind-Value="_stepConfig_Capability"
                                                  Label="Capability" Class="mb-2"
                                                  HelperText="e.g., ad-password-reset" />
                                    break;
                                case StepType.Condition:
                                    <MudTextField @bind-Value="_stepConfig_Condition"
                                                  Label="Condition" Class="mb-2"
                                                  HelperText="e.g., confidence >= 0.8" />
                                    break;
                                case StepType.Notify:
                                    <MudSelect @bind-Value="_stepConfig_NotifyType" Label="Notify Type" Class="mb-2" T="string">
                                        <MudSelectItem Value="@("email")">Email</MudSelectItem>
                                        <MudSelectItem Value="@("teams")">Teams</MudSelectItem>
                                        <MudSelectItem Value="@("ticket")">Ticket Comment</MudSelectItem>
                                    </MudSelect>
                                    break;
                                case StepType.SubWorkflow:
                                    <MudSelect Value="_stepConfig_SubWorkflowId"
                                               ValueChanged="@((Guid? val) => OnSubWorkflowChanged(val))"
                                               Label="Target Workflow" Class="mb-2"
                                               T="Guid?" Clearable="true"
                                               HelperText="Select the workflow to execute as a sub-step">
                                        @foreach (var wf in _availableWorkflows.Where(w => w.IsActive && w.Id != Id))
                                        {
                                            <MudSelectItem T="Guid?" Value="@((Guid?)wf.Id)">
                                                @(wf.DisplayName ?? wf.Name)
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                    @if (_stepConfig_SubWorkflowId.HasValue)
                                    {
                                        var selectedWf = _availableWorkflows.FirstOrDefault(w => w.Id == _stepConfig_SubWorkflowId);
                                        if (selectedWf != null)
                                        {
                                            <MudText Typo="Typo.caption" Class="mb-1" Style="color: #888;">
                                                @(selectedWf.Description ?? "No description")
                                            </MudText>
                                            <MudText Typo="Typo.caption" Style="color: #666;">
                                                Steps: @selectedWf.StepCount | Version: @selectedWf.Version
                                            </MudText>
                                        }
                                    }
                                    break;
                                case StepType.Approval:
                                    <MudTextField @bind-Value="_stepConfig_DescriptionTemplate"
                                                  Label="Description Template" Lines="3" Class="mb-2"
                                                  HelperText="Mustache template: {{ticket_type}}, {{confidence}}, {{affected_user}}" />
                                    <MudNumericField @bind-Value="_stepConfig_AutoApproveThreshold"
                                                     Label="Auto-Approve Threshold" Class="mb-2"
                                                     Min="0.0m" Max="1.01m" Step="0.05m" Format="F2"
                                                     T="decimal?"
                                                     HelperText="Confidence >= threshold auto-approves. Leave empty or >1.0 to always require human." />
                                    <MudNumericField @bind-Value="_stepConfig_TimeoutMinutes"
                                                     Label="Timeout (minutes)" Class="mb-2"
                                                     Min="0" T="int?"
                                                     HelperText="Auto-escalate after N minutes. Empty = no timeout." />
                                    <MudSelect @bind-Value="_stepConfig_TimeoutAction" Label="Timeout Action" Class="mb-2" T="string">
                                        <MudSelectItem Value="@("escalate")">Escalate (follow rejected path)</MudSelectItem>
                                        <MudSelectItem Value="@("auto_approve")">Auto-Approve (follow approved path)</MudSelectItem>
                                    </MudSelect>
                                    <MudTextField @bind-Value="_stepConfig_ContextFieldsToDisplay"
                                                  Label="Context Fields to Display" Class="mb-2"
                                                  HelperText="Comma-separated: ticket_type, confidence, affected_user, reasoning" />
                                    break;
                            }

                            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="MudBlazor.Size.Small"
                                       OnClick="DeleteSelectedStep" Class="mt-2">
                                Delete Step
                            </MudButton>
                        </MudExpansionPanel>
                    }
                </MudExpansionPanels>

                @* Action Buttons *@
                <MudStack Row="true" Spacing="2" Class="mt-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="SaveWorkflow" Disabled="_saving">
                        @(_saving ? "Saving..." : "Save")
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               OnClick="@(() => Navigation.NavigateTo("/workflows"))">
                        Cancel
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>

        @* Canvas Area *@
        <MudItem xs="12" md="9" Style="height: 100%;">
            <MudPaper Style="height: 100%; position: relative;">
                @* Toolbar *@
                <MudStack Row="true" Class="pa-2" Style="position: absolute; top: 0; right: 0; z-index: 10;">
                    <MudIconButton Icon="@Icons.Material.Filled.ZoomIn" OnClick="ZoomIn" Size="MudBlazor.Size.Small" />
                    <MudIconButton Icon="@Icons.Material.Filled.ZoomOut" OnClick="ZoomOut" Size="MudBlazor.Size.Small" />
                    <MudIconButton Icon="@Icons.Material.Filled.CenterFocusStrong" OnClick="ZoomReset" Size="MudBlazor.Size.Small" />
                </MudStack>

                @* Blazor Diagrams Canvas *@
                <CascadingValue Value="_diagram">
                    <DiagramCanvas Class="workflow-canvas" />
                </CascadingValue>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    [Parameter]
    public Guid? Id { get; set; }

    private bool _isNew => !Id.HasValue;
    private bool _saving = false;
    private BlazorDiagram _diagram = null!;

    // Workflow details
    private string _name = "";
    private string? _displayName;
    private string? _description;
    private Guid? _exampleSetId;
    private bool _isActive = true;

    // Step types palette
    private List<StepTypeInfo> _stepTypes = new();

    // Canvas state
    private List<WorkflowStepDto> _steps = new();
    private List<StepTransitionDto> _transitions = new();
    private WorkflowStepDto? _selectedStep;

    // Step edit fields (for selected step - records are immutable)
    private string? _stepEdit_Name;
    private string? _stepEdit_DisplayName;

    // Step config fields (for selected step)
    private string? _stepConfig_Capability;
    private string? _stepConfig_Condition;
    private string? _stepConfig_NotifyType;
    private string? _stepConfig_TriggerSource;

    // Example sets
    private List<ExampleSetResponse> _exampleSets = new();

    // Available workflows for sub-workflow picker (loaded on init)
    private List<WorkflowListResponse> _availableWorkflows = new();

    // Sub-workflow config fields
    private Guid? _stepConfig_SubWorkflowId;
    private string? _stepConfig_SubWorkflowName;

    // Approval step config
    private string? _stepConfig_DescriptionTemplate;
    private decimal? _stepConfig_AutoApproveThreshold;
    private int? _stepConfig_TimeoutMinutes;
    private string _stepConfig_TimeoutAction = "escalate";
    private string? _stepConfig_ContextFieldsToDisplay;

    // Node tracking
    private int _nextStepNumber = 1;

    // Lifecycle flags for async data loading
    private bool _dataLoaded = false;
    private bool _diagramPopulated = false;

    protected override void OnInitialized()
    {
        var options = new BlazorDiagramOptions
        {
            AllowMultiSelection = true,
            AllowPanning = true,
            Zoom =
            {
                Enabled = true,
                Minimum = 0.25,
                Maximum = 3.0
            },
            Links =
            {
                DefaultRouter = new NormalRouter(),
                DefaultPathGenerator = new SmoothPathGenerator()
            },
            GridSize = 20
        };

        _diagram = new BlazorDiagram(options);

        // Register our custom node widget
        _diagram.RegisterComponent<WorkflowNodeModel, WorkflowNodeWidget>();

        // Event handlers
        _diagram.SelectionChanged += OnSelectionChanged;
        _diagram.Links.Added += OnLinkAdded;
        _diagram.Links.Removed += OnLinkRemoved;
        _diagram.Nodes.Removed += OnNodeRemoved;
    }

    protected override async Task OnInitializedAsync()
    {
        // Load step types
        _stepTypes = await Http.GetFromJsonAsync<List<StepTypeInfo>>("/api/v1/workflows/step-types") ?? new();

        // Load example sets
        _exampleSets = await Http.GetFromJsonAsync<List<ExampleSetResponse>>("/api/v1/example-sets") ?? new();

        // Load available workflows (for sub-workflow picker)
        _availableWorkflows = await Http.GetFromJsonAsync<List<WorkflowListResponse>>("/api/v1/workflows") ?? new();

        if (!_isNew)
        {
            await LoadWorkflow();
            _dataLoaded = true;
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!_diagramPopulated && !_isNew && _dataLoaded && _steps.Any())
        {
            _diagramPopulated = true;
            LoadWorkflowIntoDiagram();
            StateHasChanged();
        }
    }

    private async Task LoadWorkflow()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<WorkflowDetailResponse>($"/api/v1/workflows/{Id}");
            if (response != null)
            {
                _name = response.Name;
                _displayName = response.DisplayName;
                _description = response.Description;
                _exampleSetId = response.ExampleSetId;
                _isActive = response.IsActive;

                // Convert steps to DTOs
                foreach (var step in response.Steps)
                {
                    _steps.Add(new WorkflowStepDto(
                        step.Id, step.Name, step.DisplayName, step.StepType,
                        step.ConfigurationJson, step.PositionX, step.PositionY,
                        null, step.SortOrder
                    ));
                }

                // Convert transitions
                foreach (var trans in response.Transitions)
                {
                    _transitions.Add(new StepTransitionDto(
                        trans.Id, trans.FromStepName, trans.ToStepName,
                        trans.Label, trans.Condition,
                        trans.OutputIndex, trans.InputIndex
                    ));
                }

                // Update next step number based on existing steps
                _nextStepNumber = _steps.Count + 1;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading workflow: {ex.Message}", Severity.Error);
        }
    }

    private void LoadWorkflowIntoDiagram()
    {
        var nodeMap = new Dictionary<string, WorkflowNodeModel>();

        // Create nodes
        foreach (var step in _steps.OrderBy(s => s.SortOrder))
        {
            var node = new WorkflowNodeModel(
                new Point(step.PositionX, step.PositionY),
                step.StepType,
                step.Name,
                step.DisplayName
            );
            node.StepId = step.Id;
            node.ConfigurationJson = step.ConfigurationJson;
            node.SortOrder = step.SortOrder;

            // Load sub-workflow reference if applicable
            node.LoadSubWorkflowConfig();

            _diagram.Nodes.Add(node);
            nodeMap[step.Name] = node;
        }

        // Create links from transitions
        foreach (var trans in _transitions)
        {
            if (nodeMap.TryGetValue(trans.FromStepName, out var fromNode) &&
                nodeMap.TryGetValue(trans.ToStepName, out var toNode))
            {
                var sourcePort = fromNode.GetOutputByIndex(trans.OutputIndex);
                var targetPort = toNode.ExecIn;

                if (sourcePort != null && targetPort != null)
                {
                    var link = new LinkModel(
                        new SinglePortAnchor(sourcePort),
                        new SinglePortAnchor(targetPort)
                    );
                    _diagram.Links.Add(link);
                }
            }
        }
    }

    private void AddStepFromPalette(StepTypeInfo stepType)
    {
        var stepName = $"{stepType.Value.ToString().ToLower()}-{_nextStepNumber++}";

        // Position nodes in a cascading pattern
        var xOffset = 300 + ((_nextStepNumber - 1) % 5) * 50;
        var yOffset = 100 + ((_nextStepNumber - 1) / 5) * 150;

        var node = new WorkflowNodeModel(
            new Point(xOffset, yOffset),
            stepType.Value,
            stepName,
            stepType.Name
        );
        node.SortOrder = _steps.Count;

        _diagram.Nodes.Add(node);

        _steps.Add(new WorkflowStepDto(
            null, stepName, stepType.Name, stepType.Value,
            null, xOffset, yOffset, null, _steps.Count
        ));

        StateHasChanged();
    }

    private void OnSelectionChanged(SelectableModel? model)
    {
        // Persist current step config BEFORE switching
        PersistCurrentStepConfig();

        if (model is WorkflowNodeModel node && node.Selected)
        {
            _selectedStep = _steps.FirstOrDefault(s => s.Name == node.StepName);
            LoadStepConfig();
        }
        else
        {
            _selectedStep = null;
        }
        InvokeAsync(StateHasChanged);
    }

    private void OnLinkAdded(BaseLinkModel link)
    {
        // Link is being created, will be handled when complete
    }

    private void OnLinkRemoved(BaseLinkModel link)
    {
        if (link is LinkModel linkModel)
        {
            var sourcePort = (linkModel.Source as SinglePortAnchor)?.Port;
            var targetPort = (linkModel.Target as SinglePortAnchor)?.Port;

            if (sourcePort?.Parent is WorkflowNodeModel fromNode &&
                targetPort?.Parent is WorkflowNodeModel toNode)
            {
                _transitions.RemoveAll(t =>
                    t.FromStepName == fromNode.StepName &&
                    t.ToStepName == toNode.StepName);
            }
        }
        InvokeAsync(StateHasChanged);
    }

    private void OnNodeRemoved(NodeModel nodeModel)
    {
        if (nodeModel is WorkflowNodeModel node)
        {
            _steps.RemoveAll(s => s.Name == node.StepName);
            _transitions.RemoveAll(t =>
                t.FromStepName == node.StepName ||
                t.ToStepName == node.StepName);

            if (_selectedStep?.Name == node.StepName)
                _selectedStep = null;
        }
        InvokeAsync(StateHasChanged);
    }

    private void LoadStepConfig()
    {
        // Reset all config fields
        _stepConfig_Capability = null;
        _stepConfig_Condition = null;
        _stepConfig_NotifyType = null;
        _stepConfig_TriggerSource = null;
        _stepConfig_SubWorkflowId = null;
        _stepConfig_SubWorkflowName = null;
        _stepConfig_DescriptionTemplate = null;
        _stepConfig_AutoApproveThreshold = null;
        _stepConfig_TimeoutMinutes = null;
        _stepConfig_TimeoutAction = "escalate";
        _stepConfig_ContextFieldsToDisplay = null;

        if (_selectedStep is not null)
        {
            _stepEdit_Name = _selectedStep.Name;
            _stepEdit_DisplayName = _selectedStep.DisplayName;

            if (_selectedStep.ConfigurationJson is not null)
            {
                try
                {
                    var config = JsonSerializer.Deserialize<Dictionary<string, JsonElement>>(_selectedStep.ConfigurationJson);
                    if (config != null)
                    {
                        if (config.TryGetValue("capability", out var cap))
                            _stepConfig_Capability = cap.GetString();
                        if (config.TryGetValue("condition", out var cond))
                            _stepConfig_Condition = cond.GetString();
                        if (config.TryGetValue("notifyType", out var nt))
                            _stepConfig_NotifyType = nt.GetString();
                        if (config.TryGetValue("source", out var src))
                            _stepConfig_TriggerSource = src.GetString();
                        if (config.TryGetValue("workflow_id", out var wfId) && Guid.TryParse(wfId.GetString(), out var guid))
                            _stepConfig_SubWorkflowId = guid;
                        if (config.TryGetValue("workflow_name", out var wfName))
                            _stepConfig_SubWorkflowName = wfName.GetString();

                        // Approval config
                        if (config.TryGetValue("description_template", out var dt))
                            _stepConfig_DescriptionTemplate = dt.GetString();
                        if (config.TryGetValue("auto_approve_threshold", out var aat) && aat.TryGetDecimal(out var aatVal))
                            _stepConfig_AutoApproveThreshold = aatVal;
                        if (config.TryGetValue("timeout_minutes", out var tm) && tm.TryGetInt32(out var tmVal))
                            _stepConfig_TimeoutMinutes = tmVal;
                        if (config.TryGetValue("timeout_action", out var ta))
                            _stepConfig_TimeoutAction = ta.GetString() ?? "escalate";
                        if (config.TryGetValue("context_fields_to_display", out var cfd))
                        {
                            if (cfd.ValueKind == JsonValueKind.Array)
                            {
                                var items = new List<string>();
                                foreach (var item in cfd.EnumerateArray())
                                {
                                    var s = item.GetString();
                                    if (s != null) items.Add(s);
                                }
                                _stepConfig_ContextFieldsToDisplay = string.Join(", ", items);
                            }
                            else if (cfd.ValueKind == JsonValueKind.String)
                            {
                                _stepConfig_ContextFieldsToDisplay = cfd.GetString();
                            }
                        }
                    }
                }
                catch { }
            }
        }
    }

    private void UpdateStepName(string newName)
    {
        if (_selectedStep is null || string.IsNullOrWhiteSpace(newName)) return;

        _stepEdit_Name = newName;
        var index = _steps.FindIndex(s => s.Name == _selectedStep.Name);
        if (index >= 0)
        {
            // Also update the node model
            var node = _diagram.Nodes.OfType<WorkflowNodeModel>()
                .FirstOrDefault(n => n.StepName == _selectedStep.Name);
            if (node != null)
            {
                node.StepName = newName;
            }

            _steps[index] = _steps[index] with { Name = newName };
            _selectedStep = _steps[index];
        }
    }

    private void UpdateStepDisplayName(string newDisplayName)
    {
        if (_selectedStep is null) return;

        _stepEdit_DisplayName = newDisplayName;
        var index = _steps.FindIndex(s => s.Name == _selectedStep.Name);
        if (index >= 0)
        {
            // Also update the node model
            var node = _diagram.Nodes.OfType<WorkflowNodeModel>()
                .FirstOrDefault(n => n.StepName == _selectedStep.Name);
            if (node != null)
            {
                node.DisplayName = newDisplayName;
                node.Refresh();
            }

            _steps[index] = _steps[index] with { DisplayName = newDisplayName };
            _selectedStep = _steps[index];
        }
    }

    private void DeleteSelectedStep()
    {
        if (_selectedStep is null) return;

        var node = _diagram.Nodes.OfType<WorkflowNodeModel>()
            .FirstOrDefault(n => n.StepName == _selectedStep.Name);

        if (node != null)
        {
            _diagram.Nodes.Remove(node);
        }
    }

    // Zoom controls
    private void ZoomIn()
    {
        _diagram.SetZoom(_diagram.Zoom + 0.1);
    }

    private void ZoomOut()
    {
        _diagram.SetZoom(_diagram.Zoom - 0.1);
    }

    private void ZoomReset()
    {
        _diagram.SetZoom(1.0);
        _diagram.SetPan(0, 0);
    }

    // Save workflow
    private async Task SaveWorkflow()
    {
        _saving = true;
        try
        {
            // Persist current step config before rebuilding
            PersistCurrentStepConfig();

            // Build steps and transitions from diagram state
            BuildStepsAndTransitionsFromDiagram();

            if (_isNew)
            {
                // Create workflow first
                var createRequest = new CreateWorkflowRequest(_name, _displayName, _description, _exampleSetId, _isActive);
                var createResponse = await Http.PostAsJsonAsync("/api/v1/workflows", createRequest);

                if (!createResponse.IsSuccessStatusCode)
                {
                    var error = await createResponse.Content.ReadAsStringAsync();
                    Snackbar.Add($"Error: {error}", Severity.Error);
                    return;
                }

                var created = await createResponse.Content.ReadFromJsonAsync<WorkflowListResponse>();
                Id = created?.Id;
            }
            else
            {
                // Update metadata
                var updateRequest = new UpdateWorkflowRequest(_displayName, _description, null, _exampleSetId, _isActive);
                await Http.PutAsJsonAsync($"/api/v1/workflows/{Id}", updateRequest);
            }

            // Save layout (steps and transitions) - pass null for layoutJson since we no longer use it
            var layoutRequest = new SaveWorkflowLayoutRequest(null, _steps.ToList(), _transitions.ToList());
            var layoutResponse = await Http.PutAsJsonAsync($"/api/v1/workflows/{Id}/layout", layoutRequest);

            if (layoutResponse.IsSuccessStatusCode)
            {
                Snackbar.Add("Workflow saved successfully", Severity.Success);
                if (_isNew)
                {
                    Navigation.NavigateTo($"/workflows/designer/{Id}");
                }
            }
            else
            {
                var error = await layoutResponse.Content.ReadAsStringAsync();
                Snackbar.Add($"Error saving layout: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void BuildStepsAndTransitionsFromDiagram()
    {
        _steps.Clear();
        _transitions.Clear();
        int sortOrder = 0;

        foreach (var node in _diagram.Nodes.OfType<WorkflowNodeModel>())
        {
            _steps.Add(new WorkflowStepDto(
                node.StepId,
                node.StepName,
                node.DisplayName,
                node.StepType,
                node.ConfigurationJson,
                (int)node.Position.X,
                (int)node.Position.Y,
                null, // no more DrawflowNodeId
                sortOrder++
            ));
        }

        foreach (var link in _diagram.Links.OfType<LinkModel>())
        {
            var sourcePort = (link.Source as SinglePortAnchor)?.Port;
            var targetPort = (link.Target as SinglePortAnchor)?.Port;

            if (sourcePort?.Parent is WorkflowNodeModel fromNode &&
                targetPort?.Parent is WorkflowNodeModel toNode)
            {
                _transitions.Add(new StepTransitionDto(
                    null,
                    fromNode.StepName,
                    toNode.StepName,
                    null, // label
                    null, // condition
                    fromNode.GetOutputIndex(sourcePort),
                    0     // input index (always 0, single ExecIn)
                ));
            }
        }
    }

    private void PersistCurrentStepConfig()
    {
        if (_selectedStep is null) return;

        string? configJson = null;

        switch (_selectedStep.StepType)
        {
            case StepType.Trigger when !string.IsNullOrEmpty(_stepConfig_TriggerSource):
                configJson = JsonSerializer.Serialize(new Dictionary<string, string> { ["source"] = _stepConfig_TriggerSource });
                break;
            case StepType.Execute when !string.IsNullOrEmpty(_stepConfig_Capability):
                configJson = JsonSerializer.Serialize(new Dictionary<string, string> { ["capability"] = _stepConfig_Capability });
                break;
            case StepType.Condition when !string.IsNullOrEmpty(_stepConfig_Condition):
                configJson = JsonSerializer.Serialize(new Dictionary<string, string> { ["condition"] = _stepConfig_Condition });
                break;
            case StepType.Notify when !string.IsNullOrEmpty(_stepConfig_NotifyType):
                configJson = JsonSerializer.Serialize(new Dictionary<string, string> { ["notifyType"] = _stepConfig_NotifyType });
                break;
            case StepType.SubWorkflow when _stepConfig_SubWorkflowId.HasValue:
                var subWf = _availableWorkflows.FirstOrDefault(w => w.Id == _stepConfig_SubWorkflowId);
                if (subWf != null)
                {
                    configJson = JsonSerializer.Serialize(new Dictionary<string, string>
                    {
                        ["workflow_id"] = subWf.Id.ToString(),
                        ["workflow_name"] = subWf.Name
                    });
                }
                break;
            case StepType.Approval:
                configJson = BuildApprovalConfigJson();
                break;
        }

        if (configJson == null) return;

        var index = _steps.FindIndex(s => s.Name == _selectedStep.Name);
        if (index >= 0)
        {
            _steps[index] = _steps[index] with { ConfigurationJson = configJson };

            // Also update the node model
            var node = _diagram.Nodes.OfType<WorkflowNodeModel>()
                .FirstOrDefault(n => n.StepName == _selectedStep.Name);
            if (node != null)
            {
                node.ConfigurationJson = configJson;

                // Update sub-workflow visual on the node
                if (_selectedStep.StepType == StepType.SubWorkflow)
                {
                    var wf = _availableWorkflows.FirstOrDefault(w => w.Id == _stepConfig_SubWorkflowId);
                    node.ReferencedWorkflowId = _stepConfig_SubWorkflowId;
                    node.ReferencedWorkflowName = wf?.Name;
                    node.Refresh();
                }
            }
        }
    }

    private string BuildApprovalConfigJson()
    {
        // Start with existing config to preserve fields we don't have UI for
        var existingConfigJson = _selectedStep?.ConfigurationJson;
        JsonObject approvalConfig = new();
        if (!string.IsNullOrEmpty(existingConfigJson))
        {
            try { approvalConfig = JsonNode.Parse(existingConfigJson)?.AsObject() ?? new(); }
            catch { approvalConfig = new(); }
        }

        if (!string.IsNullOrEmpty(_stepConfig_DescriptionTemplate))
            approvalConfig["description_template"] = _stepConfig_DescriptionTemplate;
        if (_stepConfig_AutoApproveThreshold.HasValue)
            approvalConfig["auto_approve_threshold"] = (double)_stepConfig_AutoApproveThreshold.Value;
        if (_stepConfig_TimeoutMinutes.HasValue)
            approvalConfig["timeout_minutes"] = _stepConfig_TimeoutMinutes.Value;
        if (!string.IsNullOrEmpty(_stepConfig_TimeoutAction))
            approvalConfig["timeout_action"] = _stepConfig_TimeoutAction;
        if (!string.IsNullOrEmpty(_stepConfig_ContextFieldsToDisplay))
        {
            var fields = _stepConfig_ContextFieldsToDisplay
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            var arr = new JsonArray();
            foreach (var f in fields) arr.Add(f);
            approvalConfig["context_fields_to_display"] = arr;
        }

        return approvalConfig.ToJsonString();
    }

    private void OnSubWorkflowChanged(Guid? newValue)
    {
        _stepConfig_SubWorkflowId = newValue;

        // Update node visual immediately
        if (_selectedStep != null)
        {
            var node = _diagram.Nodes.OfType<WorkflowNodeModel>()
                .FirstOrDefault(n => n.StepName == _selectedStep.Name);
            if (node != null)
            {
                var wf = _availableWorkflows.FirstOrDefault(w => w.Id == newValue);
                node.ReferencedWorkflowId = newValue;
                node.ReferencedWorkflowName = wf?.Name;
                node.Refresh();
            }
        }
    }

    private void AddSubWorkflowFromPalette(WorkflowListResponse targetWorkflow)
    {
        var stepName = $"sub-{targetWorkflow.Name}-{_nextStepNumber++}";

        // Position nodes in a cascading pattern
        var xOffset = 300 + ((_nextStepNumber - 1) % 5) * 50;
        var yOffset = 100 + ((_nextStepNumber - 1) / 5) * 150;

        var node = new WorkflowNodeModel(
            new Point(xOffset, yOffset),
            StepType.SubWorkflow,
            stepName,
            targetWorkflow.DisplayName ?? targetWorkflow.Name
        );
        node.SortOrder = _steps.Count;
        node.ReferencedWorkflowId = targetWorkflow.Id;
        node.ReferencedWorkflowName = targetWorkflow.Name;

        // Pre-populate config
        var config = new Dictionary<string, string>
        {
            ["workflow_id"] = targetWorkflow.Id.ToString(),
            ["workflow_name"] = targetWorkflow.Name
        };
        node.ConfigurationJson = JsonSerializer.Serialize(config);

        _diagram.Nodes.Add(node);

        _steps.Add(new WorkflowStepDto(
            null, stepName, targetWorkflow.DisplayName ?? targetWorkflow.Name,
            StepType.SubWorkflow,
            node.ConfigurationJson, xOffset, yOffset, null, _steps.Count
        ));

        StateHasChanged();
    }

    private string? DetermineTriggerType()
    {
        var triggerStep = _steps.FirstOrDefault(s => s.StepType == StepType.Trigger);
        if (triggerStep?.ConfigurationJson != null)
        {
            try
            {
                var config = JsonSerializer.Deserialize<Dictionary<string, string>>(triggerStep.ConfigurationJson);
                if (config?.TryGetValue("source", out var source) == true)
                    return source;
            }
            catch { }
        }
        return triggerStep != null ? "servicenow" : null;
    }

    public void Dispose()
    {
        _diagram.SelectionChanged -= OnSelectionChanged;
        _diagram.Links.Added -= OnLinkAdded;
        _diagram.Links.Removed -= OnLinkRemoved;
        _diagram.Nodes.Removed -= OnNodeRemoved;
    }
}
