@if (ProviderId == "servicenow" && AccountType == "basic-auth")
{
    <div class="mb-3">
        <label class="form-label">Username</label>
        <input type="text" class="form-control" @bind="Username" placeholder="service-account-user" />
    </div>
    <div class="mb-3">
        <label class="form-label">Password</label>
        <input type="password" class="form-control" @bind="Password" placeholder="Enter password" />
    </div>
}
else if (ProviderId == "servicenow" && AccountType == "oauth")
{
    <div class="mb-3">
        <label class="form-label">Client ID</label>
        <input type="text" class="form-control" @bind="ClientId" placeholder="Enter OAuth client ID" />
    </div>
    <div class="mb-3">
        <label class="form-label">Client Secret</label>
        <input type="password" class="form-control" @bind="ClientSecret" placeholder="Enter OAuth client secret" />
    </div>
}
else if ((ProviderId == "llm-openai" || ProviderId == "llm-anthropic") && AccountType == "api-key")
{
    <div class="mb-3">
        <label class="form-label">API Key</label>
        <input type="password" class="form-control" @bind="ApiKey" placeholder="sk-..." />
        <div class="form-text">Enter your @(ProviderId == "llm-openai" ? "OpenAI" : "Anthropic") API key</div>
    </div>
}
else if (ProviderId == "windows-ad" && AccountType == "traditional")
{
    <div class="mb-3">
        <label class="form-label">Username</label>
        <input type="text" class="form-control" @bind="Username" placeholder="DOMAIN\\username or username@domain.com" />
    </div>
    <div class="mb-3">
        <label class="form-label">Password</label>
        <input type="password" class="form-control" @bind="Password" placeholder="Enter password" />
    </div>
}
else if (ProviderId == "llm-ollama" ||
         (ProviderId == "windows-ad" && (AccountType == "gmsa" || AccountType == "current-user")))
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No credentials required for this account type.
    </div>
}
else
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle"></i> Credential form not configured for provider @ProviderId with account type @AccountType.
    </div>
}

@code {
    [Parameter]
    public string ProviderId { get; set; } = "";

    [Parameter]
    public string AccountType { get; set; } = "";

    [Parameter]
    public string? Username { get; set; }

    [Parameter]
    public EventCallback<string?> UsernameChanged { get; set; }

    [Parameter]
    public string? Password { get; set; }

    [Parameter]
    public EventCallback<string?> PasswordChanged { get; set; }

    [Parameter]
    public string? ApiKey { get; set; }

    [Parameter]
    public EventCallback<string?> ApiKeyChanged { get; set; }

    [Parameter]
    public string? ClientId { get; set; }

    [Parameter]
    public EventCallback<string?> ClientIdChanged { get; set; }

    [Parameter]
    public string? ClientSecret { get; set; }

    [Parameter]
    public EventCallback<string?> ClientSecretChanged { get; set; }
}
