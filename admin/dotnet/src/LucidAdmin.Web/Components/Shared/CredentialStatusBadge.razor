@if (StorageType == "None")
{
    <span class="badge bg-secondary" title="No credentials required">N/A</span>
}
else if (!string.IsNullOrEmpty(CredentialReference) && StorageType == "Environment")
{
    <span class="badge bg-info" title="Using environment variable: @CredentialReference">Env Var</span>
}
else if (HasCredentials)
{
    <span class="badge bg-success" title="Credentials stored in @StorageType">Configured</span>
}
else
{
    <span class="badge bg-warning text-dark" title="No credentials configured">Not Set</span>
}

@code {
    [Parameter]
    public bool HasCredentials { get; set; }

    [Parameter]
    public string? CredentialReference { get; set; }

    [Parameter]
    public string StorageType { get; set; } = "Database";
}
