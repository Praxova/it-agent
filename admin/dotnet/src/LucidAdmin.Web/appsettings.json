{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=lucid-admin.db"
  },
  "Database": {
    "Provider": "Sqlite"
  },
  "Jwt": {
    "Issuer": "LucidAdmin",
    "Audience": "LucidAdmin",
    "ExpirationMinutes": "60"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/lucid-admin-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },
  "ActiveDirectory": {
    "Enabled": true,
    "Domain": "montanifarms.com",
    "LdapServer": "172.16.119.20",
    "LdapPort": 389,
    "UseLdaps": false,
    "SearchBase": "DC=montanifarms,DC=com",
    "BindUserDn": "",
    "BindPasswordEnvVar": "PRAXOVA_AD_BIND_PASSWORD",
    "RoleMapping": {
      "AdminGroup": "PraxovaAdmin-Admins",
      "OperatorGroup": "PraxovaAdmin-Operators",
      "ViewerGroup": "PraxovaAdmin-Viewers"
    },
    "DefaultRole": "Viewer",
    "RequireRoleGroup": false
  },
  "AllowedHosts": "*"
}
