# ─────────────────────────────────────────────────────────────────
# terraform.tfvars.example
# Copy to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.
# ─────────────────────────────────────────────────────────────────

# The release tag you built and deployed with build-containers.sh
# Changing this triggers a re-run of the full bootstrap sequence.
deployment_tag = "dev"

# SSH credentials for the Docker host VM
docker_host_ip       = "10.0.0.51"
docker_host_user     = "packer"
docker_host_password = "packer"

# Portal admin credentials
# Change this if you've updated the default password after first login.
portal_admin_user     = "admin"
portal_admin_password = "admin"

# Agent configuration
agent_name         = "test-agent"
agent_display_name = "Helpdesk Agent"

# Ollama model to pre-pull. Must match what the agent expects.
# First pull is slow (~4GB download for llama3.1). Subsequent runs are fast.
ollama_model = "llama3.1"
