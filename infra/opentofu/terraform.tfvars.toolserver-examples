# =============================================================================
# terraform.tfvars — Tool Server Examples
# =============================================================================
# Add these to your existing terraform.tfvars alongside the Proxmox credentials
# you already have. Only uncomment what you need for your current phase.
# =============================================================================

# =============================================================================
# PHASE 1: Basic Install (LocalSystem) — Start here
# =============================================================================
# You don't actually need to add anything! All defaults work out of the box.
# Just make sure the MSI exists at the default path after 'make build'.
#
# The only thing you might customize:
#
# toolserver_msi_path = "/home/alton/Documents/lucid-it-agent/build/artifacts/PraxovaToolServer.msi"


# =============================================================================
# PHASE 2: gMSA Service Account — When you're ready for managed identities
# =============================================================================
# gMSA accounts are the gold standard for Windows services. AD manages the
# password automatically (rotates every 30 days). The trailing '$' tells
# Windows this is a managed service account, not a regular user.
#
# Prerequisites on DC01 before this works:
#   - KDS root key created:  Add-KdsRootKey -EffectiveImmediately
#   - gMSA created:          New-ADServiceAccount -Name svc-toolserver ...
#   - TOOL01 allowed to use:  Set-ADServiceAccount ... -PrincipalsAllowedToRetrieveManagedPassword TOOL01$
#
# toolserver_service_account = "MONTANIFARMS\\svc-toolserver$"
# toolserver_domain_name     = "montanifarms.com"


# =============================================================================
# PHASE 3: Domain Account + TLS — Full production-style deployment
# =============================================================================
# This is the target state: dedicated service account, TLS certs, custom ports.
#
# toolserver_service_account  = "MONTANIFARMS\\svc-praxova"
# toolserver_service_password = "YourSecurePasswordHere"  # Move to vault in prod!
# toolserver_domain_name      = "montanifarms.com"
# toolserver_cert_path        = "C:\\certs\\toolserver.pfx"
# toolserver_cert_key_path    = "C:\\certs\\toolserver.key"
# toolserver_https_port       = 8443
# toolserver_http_port        = 8080


# =============================================================================
# OPTIONAL: Skip app deployment (infra-only iteration)
# =============================================================================
# Set this to false when you're working on the VM/domain infrastructure
# and don't want to wait for the MSI install on every apply.
#
# toolserver_deploy_enabled = false
