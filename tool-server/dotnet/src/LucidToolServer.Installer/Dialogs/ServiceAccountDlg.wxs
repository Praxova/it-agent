<?xml version="1.0" encoding="UTF-8"?>
<!--
  Service Account Dialog (placeholder for future custom UI)

  Currently, service account configuration is handled via:
  1. Silent install properties: SERVICE_ACCOUNT, SERVICE_ACCOUNT_PASSWORD
  2. Post-install script: configure-toolserver.ps1

  Example silent install with gMSA:
    msiexec /i PraxovaToolServer.msi /qn SERVICE_ACCOUNT="MONTANIFARMS\svc-toolserver$"

  Example silent install with domain account:
    msiexec /i PraxovaToolServer.msi /qn SERVICE_ACCOUNT="MONTANIFARMS\svc-praxova" SERVICE_ACCOUNT_PASSWORD="password"

  Future: This file will contain a WiX custom dialog with:
  - Radio buttons: LocalSystem / gMSA / Domain Account
  - Text field: Service account name
  - Password field: Password (for domain accounts only)
  - Help text explaining gMSA is recommended for AD operations
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <!-- Placeholder for future ServiceAccount dialog UI -->
  </Fragment>
</Wix>
