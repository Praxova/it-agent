<Project Sdk="WixToolset.Sdk/5.0.1">
  <PropertyGroup>
    <OutputType>Package</OutputType>
    <InstallerPlatform>x64</InstallerPlatform>
  </PropertyGroup>

  <!-- WiX extension packages for Firewall, UI, and Util -->
  <ItemGroup>
    <PackageReference Include="WixToolset.Firewall.wixext" Version="5.0.1" />
    <PackageReference Include="WixToolset.UI.wixext" Version="5.0.1" />
    <PackageReference Include="WixToolset.Util.wixext" Version="5.0.1" />
  </ItemGroup>

  <!-- Reference the tool server project for harvesting published files -->
  <ItemGroup>
    <ProjectReference Include="..\LucidToolServer\LucidToolServer.csproj" />
  </ItemGroup>

</Project>
