<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <!--
    Prerequisites Bundle
    This is a separate WiX Bundle (produces an EXE bootstrapper) that:
    1. Checks for .NET 8 ASP.NET Core Runtime
    2. Checks for VC++ Redist
    3. Installs missing prerequisites silently
    4. Then runs the main MSI installer

    Build this as: PraxovaToolServer-Setup.exe
  -->

  <Bundle Name="Praxova IT Agent Tool Server Setup"
          Version="1.0.0.0"
          Manufacturer="Praxova"
          UpgradeCode="75E0E3D8-433C-4932-B984-65A17DD50C8C"
          IconSourceFile="Assets\icon.ico">

    <BootstrapperApplication>
      <bal:WixStandardBootstrapperApplication
        LicenseUrl="https://www.apache.org/licenses/LICENSE-2.0"
        Theme="hyperlinkLargeLicense"
        LogoFile="Assets\icon.ico" />
    </BootstrapperApplication>

    <Chain>
      <!-- .NET 8 ASP.NET Core Hosting Bundle -->
      <ExePackage Id="DotNet8AspNetCore"
                  Name="ASP.NET Core 8.0 Runtime"
                  DownloadUrl="https://download.visualstudio.microsoft.com/download/pr/dotnet-hosting-8.0-win.exe"
                  InstallCommand="/install /quiet /norestart"
                  RepairCommand="/repair /quiet /norestart"
                  UninstallCommand="/uninstall /quiet /norestart"
                  PerMachine="yes"
                  DetectCondition="NETCORERUNTIME80_X64"
                  Vital="yes">
        <!--
          Detection: Check registry for .NET 8 ASP.NET Core Runtime
          HKLM\SOFTWARE\dotnet\Setup\InstalledVersions\x64\sharedfx\Microsoft.AspNetCore.App
        -->
      </ExePackage>

      <!-- Visual C++ Redistributable 2015-2022 (x64) -->
      <ExePackage Id="VCRedist"
                  Name="Visual C++ Redistributable 2015-2022"
                  DownloadUrl="https://aka.ms/vs/17/release/vc_redist.x64.exe"
                  InstallCommand="/install /quiet /norestart"
                  RepairCommand="/repair /quiet /norestart"
                  UninstallCommand="/uninstall /quiet /norestart"
                  PerMachine="yes"
                  DetectCondition="VCREDIST2022_X64"
                  Vital="no">
        <!--
          Detection: Check registry
          HKLM\SOFTWARE\Microsoft\VisualStudio\14.0\VC\Runtimes\x64
        -->
      </ExePackage>

      <!-- Main MSI installer (runs after prerequisites) -->
      <MsiPackage Id="PraxovaToolServerMsi"
                  SourceFile="$(var.LucidToolServer.Installer.TargetPath)"
                  Vital="yes" />
    </Chain>
  </Bundle>
</Wix>
